dth":false,"content_width":800,"border_thickness":0,"section_radius":0}},"f53d90e6-b2ae-42ca-a7db-ee766ab4cfac":{"type":"multirow","blocks":{"template--20347560395094__f53d90e6-b2ae-42ca-a7db-ee766ab4cfac-row-1":{"type":"row","settings":{"image":"shopify:\/\/shop_images\/Bildschirmfoto_2024-01-05_um_09.22.49.png","caption":"","heading":"Digitaler Knobelspaß","text":"<p>Fordere deine Familie mit spannenden Challenges heraus. Eine Familienaktivität, die den Zusammenhalt stärkt und die reale mit der virtuellen Welt verbindet. <\/p>","button_label":"","button_link":""}},"template--20347560395094__f53d90e6-b2ae-42ca-a7db-ee766ab4cfac-row-2":{"type":"row","settings":{"image":"shopify:\/\/shop_images\/Bildschirmfoto_2024-01-05_um_09.22.49.png","caption":"","heading":"Nervenkitzel für jedes Alter","text":"<p>Von kleinen Detektiven bis zu erfahrenen Abenteurern: Escape This! fesselt die Welt der Jugendlichen, während spielerische Elemente die Jüngsten begeistern. Mit unseren altersgerechten Rätseln und verschiedenen Schwierigkeitsgraden findet sich Action für jedes Familienmitglied.<\/p>","button_label":"","button_link":""}},"template--20347560395094__f53d90e6-b2ae-42ca-a7db-ee766ab4cfac-row-3":{"type":"row","settings":{"image":"shopify:\/\/shop_images\/Bildschirmfoto_2024-01-05_um_09.22.49.png","caption":"","heading":"Bewegung im Freien","text":"<p>Escape This! bringt Familien nach draußen. Wir verbinden Spaß mit Bewegung im Freien - ideal zum Auspowern!<\/p>","button_label":"","button_link":""}},"row_jGBgfn":{"type":"row","settings":{"caption":"Caption","heading":"Row","text":"<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.<\/p>","button_label":"Button label","button_link":""}},"e89bf9ac-1e31-4227-90a5-2d014d20905d":{"type":"row","settings":{"image":"shopify:\/\/shop_images\/Bildschirmfoto_2024-01-05_um_09.22.49.png","caption":"","heading":"Ein Ticket für die ganze Familie","text":"<p>Kaufe dein erschwingliches Ticket mit Festpreis und spiele mit bis zu 8 Smartphones. Begleiter ohne eigenes Handy, wie Nachwuchs oder Vierbeiner, können somit natürlich kostenlos mit dabei sein!<\/p>","button_label":"","button_link":""}},"05b63a94-b6a4-4252-9295-f21b97d2c49b":{"type":"row","settings":{"image":"shopify:\/\/shop_images\/Bildschirmfoto_2024-01-05_um_09.22.49.png","caption":"","heading":"Familien-freundliche Wege","text":"<p>Escape This! bietet familienfreundliche Wege in Innenstadtnähe – bequem erreichbar mit öffentlichen Verkehrsmitteln. Entdecke auf spielerische Art die schönen Orte deiner Stadt.<\/p>","button_label":"","button_link":""}},"f4e9fb06-eea2-412b-9937-47c70a43e9e9":{"type":"row","settings":{"image":"shopify:\/\/shop_images\/Bildschirmfoto_2024-01-05_um_09.22.49.png","caption":"","heading":"Flexibles Spielerlebnis","text":"<p>Familienspaß, wann es euch passt! Wähle deine Stadt aus und löse das Ticket innerhalb eines Jahres ein - so passt unser Spiel perfekt in den Zeitplan jeder Familie. <\/p>","button_label":"","button_link":""}},"3e822ae6-1748-4cee-b76b-013265260480":{"type":"row","settings":{"image":"shopify:\/\/shop_images\/Bildschirmfoto_2024-01-05_um_09.22.49.png","caption":"","heading":"Spielerische Wissens-vermittlung","text":"<p>Durch unsere Minispiele und Quizfragen fördert unser Spiel nicht nur Soft Skills, wie Teamfähigkeit, analytisches Denken und Zielorientierung, sondern stärkt auch die Allgemeinbildung. Ein Abenteuer, das die ganze Familie voranbringt!<\/p>","button_label":"","button_link":""}},"08b9b1c7-648e-405d-a9bb-54e54262628f":{"type":"row","settings":{"image":"shopify:\/\/shop_images\/Bildschirmfoto_2024-01-05_um_09.22.49.png","caption":"","heading":"Sicher, verlässlich, unkompliziert","text":"<p>Bei Escape This! ist Sicherheit die Basis. Wir bieten ein verlässliches und sicheres Erlebnis, gewährleisten Datenschutz sowie keine externe Werbung. Wir schaffen ein einfaches Handling für unbeschwerten Familienspaß.<\/p>","button_label":"","button_link":""}}},"block_order":["template--20347560395094__f53d90e6-b2ae-42ca-a7db-ee766ab4cfac-row-1","template--20347560395094__f53d90e6-b2ae-42ca-a7db-ee766ab4cfac-row-2","template--20347560395094__f53d90e6-b2ae-42ca-a7db-ee766ab4cfac-row-3","row_jGBgfn","e89bf9ac-1e31-4227-90a5-2d014d20905d","05b63a94-b6a4-4252-9295-f21b97d2c49b","f4e9fb06-eea2-412b-9937-47c70a43e9e9","3e822ae6-1748-4cee-b76b-013265260480","08b9b1c7-648e-405d-a9bb-54e54262628f"],"disabled":true,"settings":{"image_height":"small","desktop_image_width":"medium","image_layout":"alternate-right","heading_size":"h1","text_style":"body","button_style":"secondary","desktop_content_position":"middle","desktop_content_alignment":"center","mobile_content_alignment":"left","section_color_scheme":"","row_color_scheme":"","padding_top":20,"padding_bottom":20}},"image_banner_LReWwp":{"type":"image-banner","settings":{"image":"shopify:\/\/shop_images\/1.svg","image_overlay_opacity":0,"image_height":"adapt","image_behavior":"none","desktop_content_position":"middle-center","desktop_content_alignment":"center","show_text_box":false,"color_scheme":"","stack_images_on_mobile":true,"mobile_content_alignment":"center","show_text_below":true}},"image_banner_FiXhaB":{"type":"image-banner","settings":{"image":"shopify:\/\/shop_images\/2.1.svg","image_overlay_opacity":0,"image_height":"adapt","image_behavior":"none","desktop_content_position":"middle-center","desktop_content_alignment":"center","show_text_box":true,"color_scheme":"","stack_images_on_mobile":true,"mobile_content_alignment":"center","show_text_below":true}},"image_banner_Q6UVmM":{"type":"image-banner","settings":{"image":"shopify:\/\/shop_images\/3.svg","image_overlay_opacity":0,"image_height":"adapt","image_behavior":"none","desktop_content_position":"middle-center","desktop_content_alignment":"center","show_text_box":true,"color_scheme":"","stack_images_on_mobile":true,"mobile_content_alignment":"center","show_text_below"