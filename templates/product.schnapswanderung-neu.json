tons","settings":{"show_dynamic_checkout":false,"show_gift_card_recipient":true}},"description":{"type":"description","disabled":true,"settings":{}},"text_AmLgFd":{"type":"text","settings":{"text":"<strong>Schnapswanderung meets Escape Game!<\/strong> Löst mit der <em>Escape This!<\/em>-App den geheimnisvollen Fall der „Schnapsbrunnen-Morde“ mitten im Schwarzwald. Entlang eines abenteuerlichen Wanderwegs erwarten euer Team knifflige Rätsel an 4 Schnapsbrunnen – inklusive der Verkostung leckerer Spirituosen an jeder Station. Seid ihr clever genug, um die Hinweise richtig zu kombinieren und den Fall aufzuklären?","text_style":"subtitle"}},"icon_with_text_mVkdcf":{"type":"icon-with-text","settings":{"layout":"horizontal","icon_1":"map_pin","image_1":"shopify:\/\/shop_images\/startpunkt.png","heading_1":" Start: Heckengäu-Brennerei in Gechingen","icon_2":"stopwatch","image_2":"shopify:\/\/shop_images\/wall-clock.png","heading_2":"Dauer: 2-3h Spiel-erlebnis","icon_3":"shoe","image_3":"shopify:\/\/shop_images\/strecke.png","heading_3":"Länge der Strecke: ca. 4 km "}}},"block_order":["vendor","title","product-rating","price","variant_picker","popup_zaBNid","popup_RR4Uen","buy_buttons","description","text_AmLgFd","icon_with_text_mVkdcf"],"settings":{"enable_sticky_info":true,"color_scheme":"background-1","media_size":"small","constrain_to_viewport":true,"media_fit":"contain","gallery_layout":"thumbnail_slider","mobile_thumbnails":"show","media_position":"left","image_zoom":"lightbox","hide_variants":false,"enable_video_looping":false,"padding_top":36,"padding_bottom":24}},"multicolumn_FEtHAQ":{"type":"multicolumn","blocks":{"column_RzNQVc":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/ticket_1.png","title":"1. Ticketkauf","text":"<p>Kaufe das Ticket für deine Stadt hier auf unserer Website.<\/p>","link_label":"","link":""}},"column_MW6arx":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/password-input.png","title":"2. Ticketcode","text":"<p>Du erhältst deinen individuelle Ticketcode per Mail, sobald du deine Zahlung durchgeführt hast.<\/p>","link_label":"","link":""}},"column_EKVQdU":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/download_1.png","title":"3. App-Download","text":"<p>Zum Spielstart müssen alle Mitspieler, die neuste Version der kostenlosen \"Escape This!\"-App herunterladen. Beachte: Eine Internetverbindung sowie ein voller Handyakku sollten während des Spiels gewährleistet sein.<\/p>","link_label":"","link":""}},"column_DxF47e":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/location_1.png","title":"4. Spielstart","text":"<p>Den Startpunkt deines Escape Games findest du auf deiner Ticketbestätigung. Alle Teammitglieder (bis zu 8 Smartphones) melden sich mit dem selben Ticketcode in der App an. Achtung: Du und dein Team habt bis zu 4 Monaten Zeit, das Ticket einzulösen. Have fun!<\/p>","link_label":"","link":""}}},"block_order":["column_RzNQVc","column_MW6arx","column_EKVQdU","column_DxF47e"],"disabled":true,"settings":{"title":"So geht's:","heading_size":"h1","image_width":"third","image_ratio":"adapt","button_label":"","button_link":"","columns_desktop":2,"column_alignment":"center","background_style":"primary","color_scheme":"","columns_mobile":"1","swipe_on_mobile":false,"padding_top":36,"padding_bottom":36}},"image_with_text_CCzetn":{"type":"image-with-text","blocks":{"heading_48jYaq":{"type":"heading","settings":{"heading":"Eure Mission beginnt jetzt.","heading_size":"h1"}},"text_6jGcVV":{"type":"text","settings":{"text":"<p>Buche deine <a href=\"https:\/\/www.heckengaeu-brennerei.de\/schnapswanderungen\" target=\"_blank\">Schnapswanderung der Heckengäu-Brennerei online <\/a>(Die Buchung ist mind. 2 Tage vor Spielstart notwendig). Zum gebuchten Termin wird dein Team mit einer Broschüre, Schnapsgläsern und einem Schlüssel für die Schnapsstationen ausgestattet. Das ergänzende Escape Game Ticket kaufst du direkt hier auf der Website. Nach der Buchung erhältst du den Spielcode für dein Team. Gut ausgestattet startet ihr eure Tour: Gebt einfach euren Spielcode in der Escape This!-App ein und folgt den Hinweisen in der App. An den 4 Schnapsbrunnen könnt ihr die verschiedenen leckeren Spirituosen der Heckengäu Brennerei verkosten. <\/p><p><strong>Bitte beachte:<\/strong> <strong>Die Schnapstour selbst ist in diesem Ticket nicht enthalten. Es handelt sich hierbei um ein Ergänzungsticket, das ihr zusätzlich zur Schnapstour kauft, um das Escape Game auf der Tour zu spielen.<\/strong><\/p>","text_style":"body"}}},"block_order":["heading_48jYaq","text_6jGcVV"],"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/CellblockX-Outdoor.jpg","height":"adapt","desktop_image_width":"medium","layout":"image_first","image_behavior":"none","content_layout":"no-overlap","desktop_content_position":"top","desktop_content_alignment":"left","mobile_content_alignment":"left","section_color_scheme":"","color_scheme":"","padding_top":36,"padding_bottom":36}},"ss_hero_pro_ELmmQr":{"type":"ss-hero-pro","blocks":{"caption_jc4dhi":{"type":"caption","settings":{"caption":"<h3>SO EINFACH GEHT'S<\/h3>","caption_custom":false,"caption_font":"josefin_sans_n4","caption_size":12,"caption_size_mobile":12,"caption_advanced":false,"caption_height":130,"caption_mt":0,"caption_mt_mobile":0,"background":false,"caption_bg_opacity":0.3,"enable_blur":true,"caption_radius":100,"caption_border_thickness":1,"caption_padding_horizontal":12,"caption_padding_horizontal_mobile":12,"caption_padding_vertical":6,"caption_padding_vertical_mobile":6,"caption_color":"#f9f544","caption_bg_color":"#ffffff","caption_border_color":"#ffffff"}},"heading_yPi6iG":{"type":"heading","settings":{"heading":"<h2>In 3 Schritten zum Abenteuer.<\/h2>","heading_custom":false,"heading_font":"josefin_sans_n4","heading_accent_font":"playfair_n4","heading_size":56,"heading_size_mobile":36,"heading_advanced":false,"heading_height":130,"heading_mt":8,"headi