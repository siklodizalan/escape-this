mt_mobile":12,"arrow_color":"#121212","arrow_hover_color":"#ffffff","arrow_bg_color":"#f9f544","arrow_bg_hover_color":"#121212","arrow_border_color":"#121212","arrow_border_hover_color":"#121212","verify_icon_color":"#ffffff","verify_icon_bg":"#a1d9ee","name_color":"#ffffff","text_color":"#ffffff","stars_color":"#f6af00","slide_border_color":"#121212","action_color":"#ffffff","action_hover_color":"#ffffff","action_bg_color":"#ffffff","action_bg_hover_color":"#ffffff","action_border_color":"#ffffff","action_border_hover_color":"#ffffff","background_style":"solid","background_color":"#121212","background_gradient":"linear-gradient(180deg, #FFFFFF 0%, #F2F2F2 100%)","border_color":"#121212","margin_top":0,"margin_bottom":0,"margin_horizontal":0,"margin_horizontal_mobile":0,"padding_top":24,"padding_bottom":36,"padding_horizontal":5,"padding_horizontal_mobile":1.5,"width":"page","content_width":1200,"border_thickness":0,"section_radius":0,"lazy":true}},"ss_testimonials_2_TJFMxD":{"type":"ss-testimonials-2","blocks":{"testimonial_C7EeCr":{"type":"testimonial","settings":{"stars_count":5,"text":"<p>Wir haben als 6er Gruppe [...]  in München [...]  gespielt. Das Spiel hat uns an die bekanntesten Sehenswürdigkeiten wie den Englischen Garten geführt, [...] aber auch vorbei an schönen, etwas unbekannteren Orten.<\/p><p>Zusätzlich hat das Spiel [...] auch ein paar junge Erwachsene wirklich zum Nachdenken animiert. Es war weder zu leicht noch zu schwer.<\/p>","author":"Lennard_w","job_title":"App Store"}},"testimonial_JyYKV8":{"type":"testimonial","settings":{"stars_count":5,"text":"<p>Meine Frau und ich haben den Gefängnis-ausbruch in Darmstadt gespielt. Wir hatten viel Spaß und spielen gerne wieder. Super App!<\/p>","author":"DieterJabo","job_title":"App Store"}},"testimonial_ALXBNq":{"type":"testimonial","settings":{"stars_count":5,"text":"<p>Eine wirklich geniale Freizeitaktivität! Ich habe das Spiel schon in Heilbronn und Mainz gespielt und bin von beiden Städten sowie Spielen sehr begeistert. [...]<br\/>Die Rätsel sind kreativ und der Schwierigkeitsgrad ist sehr angenehm. [...] <\/p>","author":"Paula S.","job_title":"Google"}},"testimonial_49WEfz":{"type":"testimonial","settings":{"stars_count":5,"text":"<p>Die App ist wirklich schön aufgebaut und super verstandlich. Meine Freundinnen und ich hatten viel Spaß beim Spielen des Escape Spiels! Tolle Kombination aus Rätseln und dem Laufen durch die Stadt de Wir<\/p><p>würden jederzeit wieder spielen und können es jedem empfehlen.<\/p>","author":"DanEn15","job_title":"App Store"}},"testimonial_pVzCkR":{"type":"testimonial","settings":{"stars_count":5,"text":"<p>Habe das Spiel mit der Familie in Karlsruhe gespielt und wir hatten super viel Spaß die Stadt auf eine ganz neue Weise zu erleben, obwohl wir schon ewig hier zu Hause sind.<\/p><p>Auch unsere Teenies waren begeistert.<\/p><p>Wir werden das wiederholen... vielleicht in einer anderen Stadt.<\/p><p>Kann ich nur weiterempfehlen!<\/p>","author":"Annegarb","job_title":"App Store"}},"testimonial_cCxqWY":{"type":"testimonial","settings":{"stars_count":5,"text":"<p>Ich habe die Herausforderungen von Escape This! in Karlsruhe mit meiner Freundin gemeistert und mit viel Spaß, Geschick und Spannung gelöst. Zwar konnten wir nicht alle Ziele erreichen, aber Übung macht den Meister, also nochmals in einer anderen Stadt - weiter geht's<\/p>","author":"Ulrich R.","job_title":"Google"}},"testimonial_CTctwT":{"type":"testimonial","settings":{"stars_count":5,"text":"<p>Einfach wie ein riesiger Escape Room quasi. Mussten ein Haus in ner Stadt finden, das war sau cool.<\/p>","author":"Thorben B.","job_title":"Google"}},"testimonial_yCT6Xm":{"type":"testimonial","settings":{"stars_count":5,"text":"<p>Ich habe mit meiner Familie und meinen Freunden [...] gespielt in Darmstadt. Wir haben so viele Ecken der Stadt gesehen und hatten dabei viel Spaß beim Lösen der kniffligen Rätsel. Ausserdem waren einige Spiele sehr witzig vor allem für die Kleinen, die viel zu lachen hatten!! Wir können das Spiel auf jeden Fall weiter empfehlen [...]<\/p>","author":"Annemarie M.","job_title":"Google Play Store"}}},"block_order":["testimonial_C7EeCr","testimonial_JyYKV8","testimonial_ALXBNq","testimonial_49WEfz","testimonial_pVzCkR","testimonial_cCxqWY","testimonial_CTctwT","testimonial_yCT6Xm"],"name":"SS - Testimonials #2","settings":{"heading":"<h2>Das sagen unsere Spieler über Escape This!<\/h2>","heading_custom":false,"heading_font":"josefin_sans_n4","heading_size":40,"heading_size_mobile":28,"heading_height":130,"heading_align":"center","heading_align_mobile":"center","slider_view":3,"slider_view_mobile":1.2,"slider_delay":3,"slider_gap":24,"slider_gap_mobile":24,"slider_mt":32,"slider_mt_mobile":12,"card_padding_horizontal":32,"card_padding_horizontal_mobile":24,"card_padding_vertical":32,"card_padding_vertical_mobile":32,"card_radius":0,"card_border_thickness":0,"card_shadow":true,"card_content_align":"center","card_content_align_mobile":"center","stars_icon":"shopify:\/\/shop_images\/Stern-Bewertung.png","stars_size":16,"stars_size_mobile":16,"text_custom":false,"text_font":"josefin_sans_n4","text_size":18,"text_size_mobile":16,"text_height":150,"text_mt":20,"text_mt_mobile":20,"hide_image":true,"image_size":74,"image_size_mobile":74,"image_mt":20,"image_mt_mobile":20,"author_custom":false,"author_font":"josefin_sans_n4","author_size":16,"author_size_mobile":15,"author_height":130,"author_mt":20,"author_mt_mobile":20,"job_title_custom":false,"job_title_font":"josefin_sans_n4","job_title_size":13,"job_title_size_mobile":12,"job_title_height":130,"job_title_mt":4,"job_title_mt_mobile":4,"arrow_size":34,"arrow_size_mobile":38,"arrow_icon_size":8,"arrow_icon_size_mobile":8,"arrow_border_thickness":0,"arrow_radius":100,"arrow_hover_effect":"color","arrow_show_desktop":true,"arrow_show_mobile":true,"dots_size":8,"dots_size_mobile":8,"dots_mt":32,"dots_mt_mobile":24,"dots_show_desktop":true,"dots_show_mobile":true,"stars_color":"#00