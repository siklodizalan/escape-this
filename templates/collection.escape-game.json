{"sections":{"banner":{"type":"main-collection-banner","settings":{"show_collection_description":false,"show_collection_image":false,"color_scheme":"background-1"}},"bc1a6ccf-1067-44be-b427-3ff8886e767a":{"type":"image-banner","blocks":{"template--20232998715734__bc1a6ccf-1067-44be-b427-3ff8886e767a-heading-1":{"type":"heading","settings":{"heading":"Spannung pur!","heading_size":"h1"}},"template--20232998715734__bc1a6ccf-1067-44be-b427-3ff8886e767a-text-1":{"type":"text","settings":{"text":"Tauche ein in die gefährlichen Welten, in denen dich fesselnde Escape-Geschichten beanspruchen und in ihren Bann ziehen. Es erwarten dich, jede Menge Rätsel und Herausforderungen die darauf warten, von dir gelöst zu werden. In der Escape World gibt es kein Entkommen und die Zeit läuft niemals ab. Hier ist also jeder Willkommen der sich gerne kniffligen Aufgaben stellt und das Escape-Feeling liebt!","text_style":"body"}}},"block_order":["template--20232998715734__bc1a6ccf-1067-44be-b427-3ff8886e767a-heading-1","template--20232998715734__bc1a6ccf-1067-44be-b427-3ff8886e767a-text-1"],"settings":{"image":"shopify:\/\/shop_images\/Escape_World_Escape_This_Freizeitaktivitaet_Escape_Room.jpg","image_overlay_opacity":70,"image_height":"small","image_behavior":"none","desktop_content_position":"middle-center","desktop_content_alignment":"center","show_text_box":false,"color_scheme":"","stack_images_on_mobile":true,"mobile_content_alignment":"center","show_text_below":true}},"product-grid":{"type":"main-collection-product-grid","settings":{"products_per_page":16,"columns_desktop":4,"columns_mobile":"2","color_scheme":"background-1","image_ratio":"portrait","image_shape":"default","show_secondary_image":true,"show_vendor":false,"show_rating":false,"enable_filtering":false,"filter_type":"drawer","enable_sorting":true,"padding_top":0,"padding_bottom":40}},"6197ff29-0262-487d-92e3-a7e817eb1f90":{"type":"newsletter","blocks":{"template--20353993376086__6197ff29-0262-487d-92e3-a7e817eb1f90-head