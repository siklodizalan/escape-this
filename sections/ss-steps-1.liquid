        "type": "range",
        "id": "number_font_size",
        "min": 10,
        "max": 60,
        "step": 1,
        "unit": "px",
        "label": "Font size",
        "default": 26
      },
      {
        "type": "range",
        "id": "number_font_size_mobile",
        "min": 10,
        "max": 60,
        "step": 1,
        "unit": "px",
        "label": "Font size - mobile",
        "default": 20
      },
      {
        "type": "range",
        "id": "number_gap",
        "min": 0,
        "max": 60,
        "step": 2,
        "unit": "px",
        "label": "Gap to title",
