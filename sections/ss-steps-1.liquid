        "type": "color",
        "label": "Color",
        "id": "text_color",
        "default": "#ffffff"
      },
      {
        "type": "header",
        "content": "Section colors"
      },
      {
        "type": "color",
        "label": "Section background",
        "id": "background_color",
        "default": "#1f1f21"
      },
      {
        "type": "color_background",
        "id": "background_gradient",
        "label": "Section background gradient",
