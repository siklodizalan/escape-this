{%- endcapture -%}

<div class="section-{{ section.id }}" style="background-color:{{ background_color }}; background-image: {{ background_gradient }};">
  <div class="section-{{ section.id }}-settings">
    <div class="steps-row-{{ section.id }}">
      {% for block in step_blocks %}
        {%- liquid
          assign is_offset = false
          assign index_remainder = forloop.index0 | modulo: 2
          if index_remainder == 1
            assign is_offset = true
          endif
          assign card_stack_order = step_count | minus: forloop.index
        -%}
        <div class="step-card-{{ section.id }} step-card-{{ block.id }}{% if is_offset %} step-card-offset-{{ section.id }}{% endif %}" style="z-index: {{ card_stack_order }};" {{ block.shopify_attributes }}>
          {% unless forloop.last %}
            {% if show_footprints %}
              <div class="step-footprints-{{ section.id }}">
                {{ footprint_svg }}
                {{ footprint_svg }}
              </div>
            {% endif %}
          {% endunless %}

          <div class="step-card-head-{{ section.id }}">
            <div class="step-number-{{ section.id }}">{{ forloop.index }}</div>
            {% if block.settings.title != blank %}
              <p class="step-title-{{ section.id }}">{{ block.settings.title }}</p>
            {% endif %}
          </div>
          {% if block.settings.text != blank %}
            <div class="step-text-{{ section.id }}">{{ block.settings.text }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "SS - Steps #1",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "header",
        "content": "Layout settings"
      },
      {
        "type": "range",
        "id": "cards_gap",
        "min": 0,
        "max": 80,
        "step": 2,
        "unit": "px",
        "label": "Gap",
        "default": 20
      },
      {
        "type": "range",
        "id": "cards_gap_mobile",
        "min": 0,
        "max": 80,
        "step": 2,
        "unit": "px",
        "label": "Gap - mobile",
        "default": 16
      },
      {
        "type": "range",
        "id": "stagger_offset",
        "min": 0,
        "max": 240,
        "step": 4,
        "unit": "px",
        "label": "Stagger offset (alternating cards)",
        "default": 140
      },
      {
        "type": "checkbox",
        "id": "show_footprints",
        "label": "Show footprint icons between cards",
        "default": true
      },
      {
        "type": "color",
        "label": "Footprint color",
        "id": "footprint_color",
        "default": "#f9f544"
      },
      {
        "type": "header",
        "content": "Card settings"
      },
      {
        "type": "range",
        "id": "card_padding_horizontal",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Padding horizontal",
        "default": 40
      },
      {
        "type": "range",
        "id": "card_padding_horizontal_mobile",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Padding horizontal - mobile",
        "default": 24
      },
      {
        "type": "range",
        "id": "card_padding_vertical",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Padding vertical",
        "default": 40
      },
      {
        "type": "range",
        "id": "card_padding_vertical_mobile",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Padding vertical - mobile",
        "default": 28
      },
      {
        "type": "range",
        "id": "card_radius",
        "min": 0,
        "max": 60,
        "step": 1,
        "unit": "px",
        "label": "Roundness",
        "default": 6
      },
      {
        "type": "range",
        "id": "card_border_thickness",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "Border thickness",
        "default": 0
      },
      {
        "type": "header",
        "content": "Number settings"
      },
      {
        "type": "range",
        "id": "number_size",
        "min": 20,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Size",
        "default": 52
      },
      {
        "type": "range",
        "id": "number_size_mobile",
        "min": 20,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Size - mobile",
        "default": 44
      },
