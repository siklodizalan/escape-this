{% comment %}
  Custom section: Feedback slider with header (caption + heading) and
  top-right navigation arrows controlling a peeking image/video slider.
  Each slide can show a star rating, a quote and an author name overlay.
{% endcomment %}

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
>

{%- liquid
  assign padding_horizontal = section.settings.padding_horizontal
  assign padding_horizontal_mobile = section.settings.padding_horizontal_mobile
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign border_color = section.settings.border_color
  assign border_thickness = section.settings.border_thickness
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign margin_horizontal_mobile = section.settings.margin_horizontal_mobile
  assign margin_horizontal = section.settings.margin_horizontal
  assign background_color = section.settings.background_color
  assign background_gradient = section.settings.background_gradient
  assign full_width = section.settings.full_width
  assign content_width = section.settings.content_width
  assign lazy = section.settings.lazy
  assign section_radius = section.settings.section_radius

  assign caption = section.settings.caption
  assign caption_color = section.settings.caption_color

  assign heading = section.settings.heading
  assign heading_color = section.settings.heading_color

  assign slider_view = section.settings.slider_view
  assign slider_view_mobile = section.settings.slider_view_mobile
  assign slider_gap = section.settings.slider_gap
  assign slider_gap_mobile = section.settings.slider_gap_mobile

  assign card_height = section.settings.card_height
  assign card_height_mobile = section.settings.card_height_mobile

  assign corner_radius = section.settings.corner_radius

  assign overlay_bg_color = section.settings.overlay_bg_color
  assign overlay_padding = section.settings.overlay_padding

  assign stars_color = section.settings.stars_color
  assign stars_size = section.settings.stars_size

  assign quote_size = section.settings.quote_size
  assign quote_color = section.settings.quote_color

  assign author_size = section.settings.author_size
  assign author_color = section.settings.author_color

  assign arrow_size = section.settings.arrow_size
  assign arrow_icon_size = section.settings.arrow_icon_size
  assign arrow_color = section.settings.arrow_color
  assign arrow_bg_color = section.settings.arrow_bg_color
-%}

{%- style -%}
  .section-{{ section.id }} {
    border-top: solid {{ border_color }} {{ border_thickness }}px;
    border-bottom: solid {{ border_color }} {{ border_thickness }}px;
    margin-top: {{ margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ margin_bottom | times: 0.75 | round: 0 }}px;
    margin-left: {{ margin_horizontal_mobile }}rem;
    margin-right: {{ margin_horizontal_mobile }}rem;
    border-radius: {{ section_radius | times: 0.6 | round: 0 }}px;
    overflow: hidden;
  }

  .section-{{ section.id }}-settings {
    padding-bottom: {{ padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: calc((100% - clamp(100px, var(--page-content-width, var(--page-width)), 100%)) / 2 + {{ padding_horizontal_mobile }}rem);
    padding-right: 0;
  }

  .feedback-header-{{ section.id }} {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    padding-top: {{ padding_top | times: 0.75 | round: 0 }}px;
    padding-left: calc((100% - clamp(100px, var(--page-content-width, var(--page-width)), 100%)) / 2 + {{ padding_horizontal_mobile }}rem);
    padding-right: calc((100% - clamp(100px, var(--page-content-width, var(--page-width)), 100%)) / 2 + {{ padding_horizontal_mobile }}rem);
  }

  .feedback-caption-{{ section.id }} {
    margin: 0;
    font-size: 16px;
    color: {{ caption_color }};
    text-transform: uppercase;
    font-weight: 700;
  }

  .feedback-heading-{{ section.id }} {
    margin: 0;
    margin-top: 6px;
    font-size: 28px;
    color: {{ heading_color }};
    text-transform: uppercase;
    font-weight: 800;
  }

  .feedback-arrows-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .feedback-btn-prev-{{ section.id }},
  .feedback-btn-next-{{ section.id }} {
    position: relative;
    display: flex;
    flex-shrink: 0;
    padding: 0;
    width: {{ arrow_size }}px;
    height: {{ arrow_size }}px;
    border: 0;
    border-radius: {{ corner_radius }}px;
    background: {{ arrow_bg_color }};
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease 0s;
    cursor: pointer;
    -webkit-appearance: none;
    opacity: 1;
  }

  .feedback-btn-prev-{{ section.id }} .animate-icon,
  .feedback-btn-next-{{ section.id }} .animate-icon {
    pointer-events: none;
    display: block;
    width: 0;
    height: 0;
    border-top: {{ arrow_icon_size }}px solid transparent;
    border-bottom: {{ arrow_icon_size }}px solid transparent;
    transition: border-color .2s ease;
  }

  .feedback-btn-next-{{ section.id }} .animate-icon {
    border-left: {{ arrow_icon_size | times: 1.4 }}px solid currentColor;
    margin-left: 2px;
  }

  .feedback-btn-prev-{{ section.id }} .animate-icon {
    border-right: {{ arrow_icon_size | times: 1.4 }}px solid currentColor;
    margin-right: 2px;
  }

  .feedback-btn-prev-{{ section.id }} span,
  .feedback-btn-next-{{ section.id }} span {
    color: {{ arrow_color }};
  }

  .feedback-btn-prev-{{ section.id }}:hover,
  .feedback-btn-next-{{ section.id }}:hover {
    filter: brightness(0.9);
  }

  .feedback-btn-prev-{{ section.id }}.swiper-button-disabled,
  .feedback-btn-next-{{ section.id }}.swiper-button-disabled {
    opacity: 0.4;
  }

  .feedback-slider-{{ section.id }} {
    position: relative !important;
    margin-top: 32px;
  }

  .feedback-card-{{ section.id }} {
    position: relative !important;
    height: {{ card_height_mobile }}px;
    border-radius: {{ corner_radius }}px;
    overflow: hidden;
    box-sizing: border-box !important;
  }

  .feedback-card-{{ section.id }} video,
  .feedback-card-{{ section.id }} iframe,
  .feedback-card-{{ section.id }} img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    margin: 0;
    border: 0;
  }

  .feedback-overlay-{{ section.id }} {
    position: absolute;
    left: 16px;
    right: 16px;
    bottom: 16px;
    z-index: 2;
    padding: 16px;
    border-radius: {{ corner_radius }}px;
    background-color: {{ overlay_bg_color }};
  }

  .feedback-stars-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .feedback-stars-{{ section.id }} svg {
    display: block;
    width: {{ stars_size }}px;
    height: {{ stars_size }}px;
  }

  .feedback-quote-{{ section.id }} {
    margin: 0;
    margin-top: 8px;
    font-size: {{ quote_size }}px;
    color: {{ quote_color }};
  }

  .feedback-author-{{ section.id }} {
    margin: 0;
    margin-top: 8px;
    font-size: {{ author_size }}px;
    color: {{ author_color }};
    font-weight: 800;
  }

  @media(min-width: 1024px) {
    .section-{{ section.id }} {
      margin-top: {{ margin_top }}px;
      margin-bottom: {{ margin_bottom }}px;
      margin-left: {{ margin_horizontal }}rem;
      margin-right: {{ margin_horizontal }}rem;
      border-radius: {{ section_radius }}px;
    }

    .section-{{ section.id }}-settings {
      padding-bottom: {{ padding_bottom }}px;
      padding-left: calc((100% - clamp(100px, var(--page-content-width, var(--page-width)), 100%)) / 2 + {{ padding_horizontal }}rem);
      padding-right: 0;
    }

    .feedback-header-{{ section.id }} {
      padding-top: {{ padding_top }}px;
      padding-left: calc((100% - clamp(100px, var(--page-content-width, var(--page-width)), 100%)) / 2 + {{ padding_horizontal }}rem);
      padding-right: calc((100% - clamp(100px, var(--page-content-width, var(--page-width)), 100%)) / 2 + {{ padding_horizontal }}rem);
    }

    .feedback-caption-{{ section.id }} {
      font-size: 20px;
    }

    .feedback-heading-{{ section.id }} {
      margin-top: 8px;
      font-size: 40px;
    }

    .feedback-slider-{{ section.id }} {
      margin-top: 56px;
    }

    .feedback-card-{{ section.id }} {
      height: {{ card_height }}px;
    }

    .feedback-overlay-{{ section.id }} {
      left: {{ overlay_padding }}px;
      right: auto;
      bottom: {{ overlay_padding }}px;
      width: calc(100% - {{ overlay_padding | times: 2 }}px);
      padding: 20px;
    }
  }
{%- endstyle -%}

{% unless full_width %}
  <style>
    .section-{{ section.id }}-settings {
      max-width: {{ content_width }}px;
      margin: 0 auto;
    }
  </style>
{% endunless %}

<style>
  @media (max-width: 1023.98px) {
    .section-{{ section.id }}-settings {
      padding-right: calc((100% - clamp(100px, var(--page-content-width, var(--page-width)), 100%)) / 2 + {{ padding_horizontal_mobile }}rem);
    }
  }
</style>

{% if margin_horizontal_mobile > 0 %}
  <style>
    .section-{{ section.id }} {
      border-left: solid {{ border_color }} {{ border_thickness }}px;
      border-right: solid {{ border_color }} {{ border_thickness }}px;
    }

    @media(min-width: 1024px) {
      .section-{{ section.id }} {
        border-left: 0px;
        border-right: 0px;
      }
    }
  </style>
{% endif %}

{% if margin_horizontal > 0 %}
  <style>
    @media(min-width: 1024px) {
      .section-{{ section.id }} {
        border-left: solid {{ border_color }} {{ border_thickness }}px;
        border-right: solid {{ border_color }} {{ border_thickness }}px;
      }
    }
  </style>
{% endif %}

{% comment %} SLIDE WIDTH — Swiper runs in slidesPerView:'auto' mode, so it always measures
   the rendered CSS width below instead of computing its own. That keeps Swiper's
   internal slide positions in sync with the actual (max-width capped) rendered size. {% endcomment %}
<style>
  .feedback-slider-{{ section.id }}.preview .swiper-wrapper {
    display: flex;
    align-items: stretch;
    overflow: hidden;
  }

  .feedback-slide-{{ section.id }} {
    width: calc(100% / {{ slider_view_mobile }} - ({{ slider_gap_mobile }}px));
    flex-shrink: 0;
  }

  .feedback-slider-{{ section.id }}.preview .feedback-slide-{{ section.id }}:not(:first-child) {
    margin-left: {{ slider_gap_mobile }}px;
  }

  @media(min-width: 1024px) {
    .feedback-slide-{{ section.id }} {
      width: calc(100% / {{ slider_view }} - ({{ slider_gap }}px));
      max-width: 750px;
    }

    .feedback-slider-{{ section.id }}.preview .feedback-slide-{{ section.id }}:not(:first-child) {
      margin-left: {{ slider_gap }}px;
    }
  }
</style>

<div
  class="section-{{ section.id }} feedback-{{ section.id }}"
  style="background-color:{{ background_color }}; background-image: {{ background_gradient }};"
>
  <div class="feedback-header-{{ section.id }}">
    <div>
      {% if caption != blank %}
        <p class="feedback-caption-{{ section.id }}">{{ caption }}</p>
      {% endif %}
      {% if heading != blank %}
        <h2 class="feedback-heading-{{ section.id }}">{{ heading }}</h2>
      {% endif %}
    </div>

    <div class="feedback-arrows-{{ section.id }}">
      <button class="feedback-btn-prev-{{ section.id }}" aria-label="{{ 'general.slider.previous_slide' | t }}">
        <span class="animate-icon"></span>
      </button>
      <button class="feedback-btn-next-{{ section.id }}" aria-label="{{ 'general.slider.next_slide' | t }}">
        <span class="animate-icon"></span>
      </button>
    </div>
  </div>

  <div class="section-{{ section.id }}-settings">
    <div
      class="feedback-slider-{{ section.id }} preview swiper"
      data-gap="{{ slider_gap }}"
      data-gap-mobile="{{ slider_gap_mobile }}"
      data-view="{{ slider_view }}"
      data-view-mobile="{{ slider_view_mobile }}"
    >
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% if block.type == 'slide' %}
            <div class="feedback-slide-{{ section.id }} swiper-slide" {{ block.shopify_attributes }}>
              <div class="feedback-card-{{ section.id }}">
                {% assign video_url_id = block.settings.video_url.id %}
                {% assign loop_url = '&loop=1&playlist=' | append: video_url_id %}

                {% if block.settings.video_url != null %}
                  {% if block.settings.video_url.type == 'youtube' %}
                    <iframe
                      {% if lazy %}data-{% endif -%}
                      src="https://www.youtube.com/embed/{{ video_url_id }}?enablejsapi=1&mute=1&autoplay=1&controls=0&showinfo=0{{ loop_url }}"
                      allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                      class="lazy"
                    ></iframe>
                  {% else %}
                    <iframe
                      {% if lazy %}data-{% endif -%}
                      src="https://player.vimeo.com/video/{{ video_url_id }}?enablejsapi=1&mute=1&muted=1&autoplay=1&controls=0&showinfo=0{{ loop_url }}"
                      allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                      class="lazy"
                    ></iframe>
                  {% endif %}
                {% elsif block.settings.video != blank %}
                  <video
                    {% if lazy %}data-{% endif -%}
                    src="{{ block.settings.video.sources[1].url }}"
                    autoplay
                    muted
                    playsinline
                    preload="none"
                    loop
                    class="lazy"
                    disablepictureinpicture
                  ></video>
                {% elsif block.settings.image != blank %}
                  {%- capture sizes -%}(min-width: {{ content_width }}px) {{ content_width | divided_by: 2 }}px, calc(100vw - 32px){%- endcapture -%}
                  {{
                    block.settings.image
                    | image_url: width: 1200
                    | image_tag: loading: 'lazy', sizes: sizes, widths: '400, 600, 900, 1200, 1600'
                  }}
                {% else %}
                  {{ 'lifestyle-1' | placeholder_svg_tag }}
                {% endif %}

                {% if block.settings.quote != blank or block.settings.author != blank %}
                  <div class="feedback-overlay-{{ section.id }}">
                    {% if block.settings.stars_count > 0 %}
                      <div class="feedback-stars-{{ section.id }}">
                        {% assign stars_count_round = block.settings.stars_count | round: 0 %}
                        {% for star in (1..stars_count_round) %}
                          <svg viewBox="0 0 16 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M8 0L10.351 4.764L15.608 5.528L11.804 9.236L12.702 14.472L8 12L3.298 14.472L4.196 9.236L0.392 5.528L5.649 4.764L8 0Z" fill="{{ stars_color }}"/>
                          </svg>
                        {% endfor %}
                      </div>
                    {% endif %}
                    {% if block.settings.quote != blank %}
                      <p class="feedback-quote-{{ section.id }}">&ldquo;{{ block.settings.quote }}&rdquo;</p>
                    {% endif %}
                    {% if block.settings.author != blank %}
                      <p class="feedback-author-{{ section.id }}">{{ block.settings.author }}</p>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/vanilla-lazyload@19.1.3/dist/lazyload.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/swiper@6.8.4/swiper-bundle.min.js" defer></script>

<script>
  function initFeedbackSlider{{ section.id | replace: '-', '' }}() {
    let lazyLoadInstance = new LazyLoad();

    window.addEventListener(
      'LazyLoad::Initialized',
      function (event) {
        window.lazyLoadInstance = event.detail.instance;
      },
      false
    );

    const sliderEl = document.querySelector(`.feedback-slider-{{ section.id }}`);
    if (!sliderEl) return;

    sliderEl.classList.remove('preview');

    new Swiper(`.feedback-slider-{{ section.id }}`, {
      speed: 300,
      loop: true,
      loopAdditionalSlides: 2,
      roundLengths: true,
      navigation: {
        nextEl: `.feedback-btn-next-{{ section.id }}`,
        prevEl: `.feedback-btn-prev-{{ section.id }}`,
      },
      slidesPerView: 'auto',
      breakpoints: {
        320: {
          spaceBetween: parseInt(sliderEl.dataset.gapMobile || 0),
        },
        1024: {
          spaceBetween: parseInt(sliderEl.dataset.gap || 0),
        },
      },
    });
  }

  document.addEventListener('DOMContentLoaded', initFeedbackSlider{{ section.id | replace: '-', '' }});

  if (Shopify.designMode) {
    document.addEventListener('shopify:section:unload', initFeedbackSlider{{ section.id | replace: '-', '' }});
    document.addEventListener('shopify:section:load', initFeedbackSlider{{ section.id | replace: '-', '' }});
  }
</script>

{% schema %}
{
  "name": "SS - Feedback slider #1",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "⚠️ Save settings to view updates"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "KUNDEN-INSIGHTS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Feedback, das zählt"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "range",
      "id": "slider_view",
      "min": 1,
      "max": 4,
      "step": 0.5,
      "label": "Slides to show",
      "default": 2
    },
    {
      "type": "range",
      "id": "slider_view_mobile",
      "min": 1,
      "max": 2,
      "step": 0.5,
      "label": "Slides to show - mobile",
      "default": 1.5
    },
    {
      "type": "range",
      "id": "slider_gap",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Gap",
      "default": 20
    },
    {
      "type": "range",
      "id": "slider_gap_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Gap - mobile",
      "default": 16
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "range",
      "id": "card_height",
      "min": 200,
      "max": 700,
      "step": 10,
      "unit": "px",
      "label": "Height",
      "default": 450
    },
    {
      "type": "range",
      "id": "card_height_mobile",
      "min": 150,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Height - mobile",
      "default": 320
    },
    {
      "type": "range",
      "id": "corner_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Roundness (card, overlay, arrows)",
      "default": 5
    },
    {
      "type": "header",
      "content": "Feedback overlay"
    },
    {
      "type": "range",
      "id": "overlay_padding",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Distance from card edges - desktop",
      "default": 40
    },
    {
      "type": "range",
      "id": "stars_size",
      "min": 8,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Stars size",
      "default": 16
    },
    {
      "type": "range",
      "id": "quote_size",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Quote size",
      "default": 16
    },
    {
      "type": "range",
      "id": "author_size",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Author size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Arrows"
    },
    {
      "type": "range",
      "id": "arrow_size",
      "min": 20,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 30
    },
    {
      "type": "range",
      "id": "arrow_icon_size",
      "min": 3,
      "max": 15,
      "step": 1,
      "unit": "px",
      "label": "Icon size",
      "default": 6
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "label": "Caption",
      "id": "caption_color",
      "default": "#f9f544"
    },
    {
      "type": "color",
      "label": "Heading",
      "id": "heading_color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "label": "Overlay background",
      "id": "overlay_bg_color",
      "default": "#191919"
    },
    {
      "type": "color",
      "label": "Stars",
      "id": "stars_color",
      "default": "#f9f544"
    },
    {
      "type": "color",
      "label": "Quote text",
      "id": "quote_color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "label": "Author text",
      "id": "author_color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "label": "Arrow icon",
      "id": "arrow_color",
      "default": "#191919"
    },
    {
      "type": "color",
      "label": "Arrow background",
      "id": "arrow_bg_color",
      "default": "#f9f544"
    },
    {
      "type": "color",
      "label": "Section background",
      "id": "background_color",
      "default": "#191919"
    },
    {
      "type": "color_background",
