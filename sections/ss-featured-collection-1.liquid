{%- liquid
  assign padding_horizontal = section.settings.padding_horizontal
  assign padding_horizontal_mobile = section.settings.padding_horizontal_mobile
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign border_color = section.settings.border_color
  assign border_thickness = section.settings.border_thickness
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign margin_horizontal_mobile = section.settings.margin_horizontal_mobile
  assign margin_horizontal = section.settings.margin_horizontal
  assign background_color = section.settings.background_color
  assign full_width = section.settings.full_width
  assign section_radius = section.settings.section_radius

  assign collection = section.settings.collection
  assign columns_desktop = section.settings.columns_desktop
  assign cards_gap = section.settings.cards_gap
  assign cards_gap_mobile = section.settings.cards_gap_mobile
  assign cards_row_gap = section.settings.cards_row_gap
  assign cards_row_gap_mobile = section.settings.cards_row_gap_mobile
  assign grid_mt = section.settings.grid_mt
  assign grid_mt_mobile = section.settings.grid_mt_mobile

  assign image_ratio = section.settings.image_ratio
  assign card_radius = section.settings.card_radius
  assign card_info_mt = section.settings.card_info_mt
  assign title_font = section.settings.title_font
  assign title_size = section.settings.title_size
  assign title_size_mobile = section.settings.title_size_mobile
  assign title_color = section.settings.title_color
  assign price_font = section.settings.price_font
  assign price_size = section.settings.price_size
  assign price_size_mobile = section.settings.price_size_mobile
  assign price_color = section.settings.price_color
  assign button_label = section.settings.button_label
  assign button_font = section.settings.button_font
  assign button_size = section.settings.button_size
  assign button_radius = section.settings.button_radius
  assign button_color = section.settings.button_color
  assign button_bg_color = section.settings.button_bg_color
  assign button_border_color = section.settings.button_border_color

  assign content_align = 'left'
  assign content_align_mobile = 'left'
  assign content_horizontal_align = 'flex-start'
  assign content_horizontal_align_mobile = 'flex-start'

  if section.index == 1
    assign loading_attribute = 'eager'
  else
    assign loading_attribute = 'lazy'
  endif
-%}

{%- style -%}
  {{ title_font | font_face: font_display: 'swap' }}
  {{ price_font | font_face: font_display: 'swap' }}
  {{ button_font | font_face: font_display: 'swap' }}

  .section-{{ section.id }} {
    border-top: solid {{ border_color }} {{ border_thickness }}px;
    border-bottom: solid {{ border_color }} {{ border_thickness }}px;
    margin-top: {{ margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ margin_bottom | times: 0.75 | round: 0 }}px;
    margin-left: {{ margin_horizontal_mobile }}rem;
    margin-right: {{ margin_horizontal_mobile }}rem;
    border-radius: {{ section_radius | times: 0.6 | round: 0 }}px;
    overflow: hidden;
  }

  .section-{{ section.id }}-settings {
    margin: 0 auto;
    padding-top: {{ padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: {{ padding_horizontal_mobile }}rem;
    padding-right: {{ padding_horizontal_mobile }}rem;
  }

  .featured-collection-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    column-gap: {{ cards_gap_mobile }}px;
    row-gap: {{ cards_row_gap_mobile }}px;
    margin-top: {{ grid_mt_mobile }}px;
  }

  .product-card-{{ section.id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .product-card-image-{{ section.id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ card_radius }}px;
    {% case image_ratio %}
      {% when 'square' %}
        aspect-ratio: 1 / 1;
      {% when 'portrait' %}
        aspect-ratio: 3 / 4;
      {% when 'landscape' %}
        aspect-ratio: 493 / 350;
      {% else %}
        aspect-ratio: auto;
    {% endcase %}
  }

  .product-card-image-{{ section.id }} img,
  .product-card-image-{{ section.id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-card-info-{{ section.id }} {
    margin-top: {{ card_info_mt }}px;
  }

  .product-card-title-{{ section.id }} {
    margin: 0;
    font-family: {{ title_font.family }}, {{ title_font.fallback_families }};
    font-weight: {{ title_font.weight }};
    font-style: {{ title_font.style }};
    font-size: {{ title_size_mobile }}px;
    color: {{ title_color }};
    text-transform: uppercase;
    line-height: 1.3;
  }

  .product-card-price-{{ section.id }} {
    margin: 8px 0 0;
    font-family: {{ price_font.family }}, {{ price_font.fallback_families }};
    font-weight: {{ price_font.weight }};
    font-style: {{ price_font.style }};
    font-size: {{ price_size_mobile }}px;
    color: {{ price_color }};
  }

  .product-card-button-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    margin-top: 16px;
    padding: 10px 24px;
    line-height: 1;
    border-radius: {{ button_radius }}px;
    border: 1px solid {{ button_border_color }};
    background-color: {{ button_bg_color }};
    color: {{ button_color }};
    font-family: {{ button_font.family }}, {{ button_font.fallback_families }};
    font-weight: {{ button_font.weight }};
    font-style: {{ button_font.style }};
    font-size: {{ button_size }}px;
    text-transform: uppercase;
    white-space: nowrap;
    transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
  }

  .product-card-{{ section.id }}:hover .product-card-button-{{ section.id }} {
    background-color: {{ button_border_color }};
    color: #191919;
  }

  @media(min-width: 750px) {
    .featured-collection-grid-{{ section.id }} {
      grid-template-columns: repeat({{ columns_desktop }}, minmax(0, 1fr));
      column-gap: {{ cards_gap }}px;
      row-gap: {{ cards_row_gap }}px;
      margin-top: {{ grid_mt }}px;
    }

    .product-card-title-{{ section.id }} {
      font-size: {{ title_size }}px;
    }

    .product-card-price-{{ section.id }} {
      font-size: {{ price_size }}px;
    }
  }

  @media(min-width: 1024px) {
    .section-{{ section.id }} {
      margin-top: {{ margin_top }}px;
      margin-bottom: {{ margin_bottom }}px;
      margin-left: {{ margin_horizontal }}rem;
      margin-right: {{ margin_horizontal }}rem;
      border-radius: {{ section_radius }}px;
    }

    .section-{{ section.id }}-settings {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      padding-left: {{ padding_horizontal }}rem;
      padding-right: {{ padding_horizontal }}rem;
    }
  }
{%- endstyle -%}

{% unless full_width %}
  <style>
    .section-{{ section.id }}-settings {
      max-width: clamp(100px, var(--page-content-width, var(--page-width)), 100%);
    }
  </style>
{% endunless %}

<div class="section-{{ section.id }}" style="background-color:{{ background_color }};">
  <div class="section-{{ section.id }}-settings">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'caption' %}
          {% render 'hero-pro-style-caption',
            block: block,
            content_align: content_align,
            content_align_mobile: content_align_mobile,
            content_horizontal_align: content_horizontal_align,
            content_horizontal_align_mobile: content_horizontal_align_mobile
          %}
          <div class="hero-caption-{{ block.id }}" {{ block.shopify_attributes }}>
            {{ block.settings.caption }}
          </div>
        {% when 'heading' %}
          {% render 'hero-pro-style-heading',
            block: block,
            content_align: content_align,
            content_align_mobile: content_align_mobile
          %}
          <div class="hero-heading-{{ block.id }}" {{ block.shopify_attributes }}>
            {{ block.settings.heading }}
          </div>
        {% when 'text' %}
          {% render 'hero-pro-style-text',
            block: block,
            content_align: content_align,
            content_align_mobile: content_align_mobile
          %}
          <div class="hero-text-{{ block.id }}" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </div>
      {% endcase %}
    {% endfor %}

    {% if collection != blank %}
      <div class="featured-collection-grid-{{ section.id }}">
        {% for product in collection.products %}
          {% render 'ss-product-card-1',
            product: product,
            section_id: section.id,
            columns_desktop: columns_desktop,
            loading_attribute: loading_attribute,
            button_label: button_label
          %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

