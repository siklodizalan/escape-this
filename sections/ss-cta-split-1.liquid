{%- liquid
  assign padding_horizontal = section.settings.padding_horizontal
  assign padding_horizontal_mobile = section.settings.padding_horizontal_mobile
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign border_color = section.settings.border_color
  assign border_thickness = section.settings.border_thickness
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign margin_horizontal_mobile = section.settings.margin_horizontal_mobile
  assign margin_horizontal = section.settings.margin_horizontal
  assign background_color = section.settings.background_color
  assign full_width = section.settings.full_width
  assign section_radius = section.settings.section_radius

  assign gap = section.settings.gap
  assign gap_mobile = section.settings.gap_mobile
  assign image_width = section.settings.image_width
  assign card_radius = section.settings.card_radius
  assign card_height = section.settings.card_height
  assign card_height_mobile = section.settings.card_height_mobile
  assign card_padding = section.settings.card_padding
  assign card_padding_mobile = section.settings.card_padding_mobile
  assign card_bg_color = section.settings.card_bg_color
  assign image_overlay_color = section.settings.image_overlay_color
  assign image_overlay_opacity = section.settings.image_overlay_opacity

  assign features_mt = section.settings.features_mt
  assign features_mt_mobile = section.settings.features_mt_mobile
  assign features_gap = section.settings.features_gap
  assign features_gap_mobile = section.settings.features_gap_mobile
  assign feature_background = section.settings.feature_background
  assign feature_bg_opacity = section.settings.feature_bg_opacity
  assign feature_enable_blur = section.settings.feature_enable_blur
  assign feature_radius = section.settings.feature_radius
  assign feature_border_thickness = section.settings.feature_border_thickness
  assign feature_padding_horizontal = section.settings.feature_padding_horizontal
  assign feature_padding_horizontal_mobile = section.settings.feature_padding_horizontal_mobile
  assign feature_padding_vertical = section.settings.feature_padding_vertical
  assign feature_padding_vertical_mobile = section.settings.feature_padding_vertical_mobile
  assign feature_icon_size = section.settings.feature_icon_size
  assign feature_icon_size_mobile = section.settings.feature_icon_size_mobile
  assign feature_icon_color = section.settings.feature_icon_color
  assign feature_text_size = section.settings.feature_text_size
  assign feature_text_size_mobile = section.settings.feature_text_size_mobile
  assign feature_text_color = section.settings.feature_text_color
  assign feature_text_height = section.settings.feature_text_height
  assign feature_bg_color = section.settings.feature_bg_color
  assign feature_border_color = section.settings.feature_border_color

  assign content_align = 'left'
  assign content_align_mobile = 'left'
  assign content_horizontal_align = 'flex-start'
  assign content_horizontal_align_mobile = 'flex-start'
-%}

{%- style -%}
  .section-{{ section.id }} {
    border-top: solid {{ border_color }} {{ border_thickness }}px;
    border-bottom: solid {{ border_color }} {{ border_thickness }}px;
    margin-top: {{ margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ margin_bottom | times: 0.75 | round: 0 }}px;
    margin-left: {{ margin_horizontal_mobile }}rem;
    margin-right: {{ margin_horizontal_mobile }}rem;
    border-radius: {{ section_radius | times: 0.6 | round: 0 }}px;
    overflow: hidden;
  }

  .section-{{ section.id }}-settings {
    margin: 0 auto;
    padding-top: {{ padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: {{ padding_horizontal_mobile }}rem;
    padding-right: {{ padding_horizontal_mobile }}rem;
  }

  .cta-split-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: {{ gap_mobile }}px;
  }

  .cta-split-image-{{ section.id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ card_radius }}px;
    height: {{ card_height_mobile }}px;
  }

  .cta-split-image-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cta-split-image-overlay-{{ section.id }} {
    position: absolute;
    inset: 0;
    background-color: {{ image_overlay_color | hex_to_rgba: image_overlay_opacity }};
  }

  .cta-split-card-{{ section.id }} {
    background-color: {{ card_bg_color }};
    border-radius: {{ card_radius }}px;
    padding: {{ card_padding_mobile }}px;
    text-transform: uppercase;
  }

  .cta-split-buttons-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
  }

  .cta-split-features-{{ section.id }} {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: {{ features_gap_mobile }}px;
    justify-content: flex-start;
    margin-top: {{ features_mt_mobile }}px;
  }

  .cta-split-feature-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    position: relative;
    z-index: 1;
  }

  .cta-split-feature-text-{{ section.id }} {
    margin: 0;
    font-size: {{ feature_text_size_mobile }}px;
    color: {{ feature_text_color }};
    line-height: {{ feature_text_height }}%;
    text-transform: unset;
    font-weight: var(--font-body-weight);
    text-wrap: balance;
    word-break: break-word;
  }

  .cta-split-feature-icon-{{ section.id }} {
    flex-shrink: 0;
    height: {{ feature_icon_size_mobile }}px;
    width: {{ feature_icon_size_mobile }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    {% if feature_background %}
      padding: {{ feature_padding_vertical_mobile }}px;
      border: {{ feature_border_thickness }}px solid {{ feature_border_color }};
      border-radius: {{ feature_radius }}px;
      background-color: {{ feature_bg_color | hex_to_rgba: feature_bg_opacity }};
      {% if feature_enable_blur %}
        backdrop-filter: blur(3px);
        -webkit-backdrop-filter: blur(3px);
      {% endif %}
    {% endif %}
  }

  .cta-split-feature-icon-{{ section.id }} img,
  .cta-split-feature-icon-{{ section.id }} svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .cta-split-feature-icon-{{ section.id }} svg path {
    fill: {{ feature_icon_color }};
  }

  .cta-split-feature-icon-{{ section.id }} svg circle {
    fill: {{ feature_icon_color }};
  }

  .cta-split-feature-icon-{{ section.id }} .refresh-{{ section.id }} path,
  .cta-split-feature-icon-{{ section.id }} .refresh-{{ section.id }} polyline {
    fill: none;
    stroke: {{ feature_icon_color }};
  }

  @media(min-width: 750px) {
    .cta-split-{{ section.id }} {
      flex-direction: row;
      align-items: stretch;
      gap: {{ gap }}px;
    }

    .cta-split-image-{{ section.id }} {
      flex: {{ image_width }} 1 0;
      height: auto;
      min-height: {{ card_height }}px;
    }

    .cta-split-card-{{ section.id }} {
      flex: {{ image_width | times: -1 | plus: 100 }} 1 0;
      padding: {{ card_padding }}px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .cta-split-features-{{ section.id }} {
      flex-direction: row;
      align-items: center;
      gap: {{ features_gap }}px;
      margin-top: {{ features_mt }}px;
    }

    .cta-split-feature-text-{{ section.id }} {
      font-size: {{ feature_text_size }}px;
    }

    .cta-split-feature-icon-{{ section.id }} {
      height: {{ feature_icon_size }}px;
      width: {{ feature_icon_size }}px;
      {% if feature_background %}
        padding: {{ feature_padding_vertical }}px;
      {% endif %}
    }
  }

  @media(min-width: 1024px) {
    .section-{{ section.id }} {
      margin-top: {{ margin_top }}px;
      margin-bottom: {{ margin_bottom }}px;
      margin-left: {{ margin_horizontal }}rem;
      margin-right: {{ margin_horizontal }}rem;
      border-radius: {{ section_radius }}px;
    }

    .section-{{ section.id }}-settings {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      padding-left: {{ padding_horizontal }}rem;
      padding-right: {{ padding_horizontal }}rem;
    }
  }
{%- endstyle -%}

{% unless full_width %}
  <style>
    .section-{{ section.id }}-settings {
      max-width: clamp(100px, var(--page-content-width, var(--page-width)), 100%);
    }
  </style>
{% endunless %}

<div class="section-{{ section.id }}" style="background-color:{{ background_color }};">
  <div class="section-{{ section.id }}-settings">
    <div class="cta-split-{{ section.id }}">
      <div class="cta-split-image-{{ section.id }}">
        {% if section.settings.image %}
          <img
            srcset="
              {{ section.settings.image | image_url: width: 600 }} 600w,
              {{ section.settings.image | image_url: width: 900 }} 900w,
              {{ section.settings.image | image_url: width: 1200 }} 1200w
            "
            src="{{ section.settings.image | image_url: width: 900 }}"
            sizes="(min-width: 750px) {{ image_width }}vw, 100vw"
            alt="{{ section.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag }}
        {% endif %}
        <div class="cta-split-image-overlay-{{ section.id }}"></div>
      </div>

      <div class="cta-split-card-{{ section.id }}">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'caption' %}
              {% render 'hero-pro-style-caption',
                block: block,
                content_align: content_align,
                content_align_mobile: content_align_mobile,
                content_horizontal_align: content_horizontal_align,
                content_horizontal_align_mobile: content_horizontal_align_mobile
              %}
              <div class="hero-caption-{{ block.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.caption }}
              </div>
            {% when 'heading' %}
              {% render 'hero-pro-style-heading',
                block: block,
                content_align: content_align,
                content_align_mobile: content_align_mobile
              %}
              <div class="hero-heading-{{ block.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.heading }}
              </div>
            {% when 'text' %}
              {% render 'hero-pro-style-text',
                block: block,
                content_align: content_align,
                content_align_mobile: content_align_mobile
              %}
              <div class="hero-text-{{ block.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {% when 'feature' %}
              {% assign next_index = forloop.index0 | plus: 1 %}
              {% assign next_block = section.blocks[next_index] %}

              {% unless feature_open %}
                <div class="cta-split-features-{{ section.id }}">
              {% endunless %}

              <div class="cta-split-feature-{{ section.id }}" {{ block.shopify_attributes }}>
                {% if block.settings.custom_icon != blank or block.settings.icon != "none" %}
                  <div class="cta-split-feature-icon-{{ section.id }}">
                    {% render 'hero-pro-icon',
                      custom_icon: block.settings.custom_icon,
                      icon: block.settings.icon,
                      content_width: 1200,
                      loading_attribute: 'lazy'
                    %}
                  </div>
                {% endif %}
                {% if block.settings.text != blank %}
                  <p class="cta-split-feature-text-{{ section.id }}">{{ block.settings.text }}</p>
                {% endif %}
              </div>

              {% assign feature_open = true %}

              {% if next_block.type != "feature" %}
                </div>
                {% assign feature_open = false %}
              {% endif %}
            {% when 'button' %}
              {% render 'hero-pro-style-button', block: block %}
          {% endcase %}
        {% endfor %}

        {% assign button_blocks = section.blocks | where: 'type', 'button' %}
        {% if button_blocks.size > 0 %}
          <div class="cta-split-buttons-{{ section.id }}">
            {% for block in button_blocks %}
              {% render 'hero-pro-block-button', block: block %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "SS - CTA Split #1",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "header",
        "content": "Image"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      },
      {
        "type": "range",
        "id": "image_overlay_opacity",
        "min": 0,
        "max": 1,
        "step": 0.1,
        "label": "Image overlay opacity",
        "default": 0.5
      },
      {
        "type": "color",
        "id": "image_overlay_color",
        "label": "Image overlay color",
        "default": "#000000"
      },
      {
        "type": "header",
        "content": "Layout"
      },
      {
        "type": "range",
        "id": "image_width",
        "min": 30,
        "max": 70,
        "step": 1,
        "unit": "%",
        "label": "Image width - desktop",
        "default": 57
      },
      {
        "type": "range",
        "id": "gap",
        "min": 0,
        "max": 60,
        "step": 2,
        "unit": "px",
        "label": "Gap",
        "default": 20
      },
      {
        "type": "range",
        "id": "gap_mobile",
        "min": 0,
        "max": 60,
        "step": 2,
        "unit": "px",
        "label": "Gap - mobile",
        "default": 16
      },
      {
        "type": "range",
        "id": "card_radius",
        "min": 0,
        "max": 40,
        "step": 1,
        "unit": "px",
        "label": "Card roundness",
        "default": 5
      },
      {
        "type": "range",
        "id": "card_height",
        "min": 200,
        "max": 600,
        "step": 10,
        "unit": "px",
        "label": "Card height - desktop",
        "default": 320
      },
      {
        "type": "range",
        "id": "card_height_mobile",
        "min": 150,
        "max": 500,
        "step": 10,
        "unit": "px",
        "label": "Image height - mobile",
        "default": 220
      },
      {
        "type": "range",
        "id": "card_padding",
        "min": 0,
        "max": 80,
        "step": 2,
        "unit": "px",
        "label": "Card padding - desktop",
        "default": 40
      },
      {
        "type": "range",
        "id": "card_padding_mobile",
        "min": 0,
        "max": 60,
        "step": 2,
        "unit": "px",
        "label": "Card padding - mobile",
        "default": 24
      },
      {
        "type": "color",
        "id": "card_bg_color",
        "label": "Card background",
        "default": "#f9f544"
      },
      {
        "type": "header",
        "content": "Features"
      },
      {
        "type": "range",
        "id": "features_mt",
        "min": 0,
        "max": 60,
        "step": 2,
        "unit": "px",
        "label": "Margin top",
        "default": 20
      },
      {
        "type": "range",
        "id": "features_mt_mobile",
        "min": 0,
        "max": 60,
        "step": 2,
        "unit": "px",
        "label": "Margin top - mobile",
        "default": 20
      },
      {
        "type": "range",
        "id": "features_gap",
        "min": 0,
        "max": 60,
        "step": 2,
        "unit": "px",
