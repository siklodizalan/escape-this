                    <path d="M2.88879 4.20634L1.33771 4.20765C1.21491 4.20765 1.08819 4.12665 1.03942 4.03608C0.981508 3.92897 0.978024 3.7992 1.04595 3.68468C1.60595 2.74414 2.34708 1.95077 3.24586 1.32722C3.37257 1.23926 3.52629 1.24274 3.64778 1.32809C3.74837 1.39907 3.82239 1.54799 3.77493 1.69429C3.5363 2.43454 3.35603 3.16869 3.2145 3.93201C3.18663 4.0818 3.056 4.2059 2.88922 4.2059L2.88879 4.20634Z"/>
                  </svg>
                {% else %}
                  <svg viewBox="0 0 16 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14.1972 10.9932L11.0471 10.9995V8.96215C11.0471 8.66171 10.8182 8.44453 10.5516 8.43626C10.2692 8.42749 10.0212 8.64954 10.0212 8.96215V10.9995L1.82855 10.9966C0.780736 10.9966 -0.00190423 10.1157 3.48005e-06 9.07415L0.00381891 6.99248L0.325746 6.99394C1.16562 6.99783 1.84715 6.35507 1.85859 5.5185C1.86956 4.68291 1.20139 4.0012 0.362469 4.00606L0.00334198 4.00801V1.89274C0.00334198 0.833643 0.823182 0 1.86432 0H10.0217V2.03687C10.0217 2.33634 10.2521 2.55449 10.5172 2.56375C10.8001 2.57348 11.0476 2.34852 11.0476 2.03785V0L14.1734 0.00389553C15.2197 0.00535635 16.0014 0.88039 15.9995 1.92731L15.9957 4.00655L15.6018 4.00801C14.79 4.01142 14.149 4.6795 14.14 5.48247C14.1309 6.30248 14.7767 6.98858 15.6013 6.99199L15.9971 6.99345L15.9957 9.11067C15.9948 10.1216 15.2226 10.9912 14.1972 10.9932ZM11.0514 6.50407L11.0481 4.44236C11.0476 4.14874 10.8158 3.93741 10.5511 3.92767C10.3045 3.9189 10.0274 4.11173 10.0274 4.40584V6.59464C10.0274 6.90093 10.3284 7.09619 10.5826 7.0699C10.8621 7.04068 11.0514 6.81864 11.0509 6.50407H11.0514Z"/>
