                    <path d="M8.99643 14.8489C8.02015 15.0505 7.06302 15.0435 6.09893 14.8702C5.98398 14.8498 5.87163 14.7975 5.81067 14.6978C5.16489 13.644 4.70854 12.3856 4.45162 11.1786C4.40721 10.97 4.59271 10.795 4.79781 10.795H10.2013C10.3158 10.795 10.4291 10.8551 10.4822 10.9247C10.5418 11.0031 10.5693 11.1263 10.544 11.23C10.2436 12.4736 9.85775 13.6035 9.18933 14.6987C9.16059 14.7457 9.06654 14.8341 8.99643 14.8485V14.8489Z"/>
                    <path d="M2.69414 9.69897H0.590037C0.408889 9.69984 0.286963 9.57661 0.243417 9.40809C-0.0831712 8.14401 -0.0827358 6.83117 0.252126 5.56883C0.29393 5.41076 0.423259 5.30321 0.589601 5.30321H2.64319C2.8509 5.30321 3.00897 5.46737 2.99199 5.67899C2.89488 6.89997 2.90882 8.10308 3.03074 9.32318C3.05034 9.51957 2.9049 9.6994 2.6937 9.6994L2.69414 9.69897Z"/>
