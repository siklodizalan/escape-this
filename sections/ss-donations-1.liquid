            {% if block.settings.text != blank %}
              <p class="donations-feature-text-{{ section.id }}">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if category_blocks.size > 0 %}
      <div class="donations-tabs-{{ section.id }}" role="tablist">
        {% for block in category_blocks %}
          <button
            type="button"
            class="donations-tab-{{ section.id }}{% if forloop.first %} is-active{% endif %}"
            data-donations-tab-{{ section.id }}
            data-target="donations-panel-{{ block.id }}-{{ section.id }}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.tab_label }}
          </button>
        {% endfor %}
      </div>

      <div class="donations-panels-{{ section.id }}">
        {% for block in category_blocks %}
          <div
            class="donations-panel-{{ section.id }}{% if forloop.first %} is-active{% endif %}"
            id="donations-panel-{{ block.id }}-{{ section.id }}"
            role="tabpanel"
          >
            <div class="donations-panel-content-{{ section.id }}">
              {% if block.settings.heading != blank %}
                <h3 class="donations-panel-heading-{{ section.id }}">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <div class="donations-panel-text-{{ section.id }}">{{ block.settings.text }}</div>
              {% endif %}
              {% if block.settings.button_label != blank %}
                <a href="{{ block.settings.button_link }}" class="donations-panel-button-{{ section.id }}">{{ block.settings.button_label }}</a>
              {% endif %}
            </div>
            <div class="donations-panel-image-{{ section.id }}">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 1500 }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}">
              {% else %}
                {{ 'image' | placeholder_svg_tag }}
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<script>
  function initDonationsTabs{{ section.id | replace: '-', '_' }}() {
    var section = document.querySelector('[data-section-id="{{ section.id }}"]') || document;
    var tabs = section.querySelectorAll('[data-donations-tab-{{ section.id }}]');

    tabs.forEach(function (tab) {
      if (tab.dataset.donationsBound) return;
      tab.dataset.donationsBound = 'true';

      tab.addEventListener('click', function () {
        var targetId = tab.getAttribute('data-target');

        tabs.forEach(function (otherTab) {
          otherTab.classList.remove('is-active');
          otherTab.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('is-active');
        tab.setAttribute('aria-selected', 'true');

        section.querySelectorAll('.donations-panel-{{ section.id }}').forEach(function (panel) {
          panel.classList.toggle('is-active', panel.id === targetId);
        });
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initDonationsTabs{{ section.id | replace: '-', '_' }});
  document.addEventListener('shopify:section:load', initDonationsTabs{{ section.id | replace: '-', '_' }});
</script>

{% schema %}
  {
    "name": "SS - Donations #1",
    "settings": [
      {
        "type": "header",
        "content": "Feature colors"
      },
      {
        "type": "color",
        "label": "Icon background",
        "id": "feature_icon_bg_color",
        "default": "#1c1c1c"
      },
