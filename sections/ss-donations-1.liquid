                    <path d="M3.95564 13.3715C4.0227 13.5478 3.99048 13.7006 3.852 13.806C3.73792 13.8927 3.5829 13.9001 3.43963 13.806C2.45203 13.1594 1.63338 12.3164 1.03463 11.2957C0.97367 11.1921 0.988475 11.0601 1.03855 10.967C1.08863 10.8738 1.2136 10.795 1.33771 10.795L2.96934 10.7958C3.1248 10.7958 3.25935 10.9047 3.29288 11.0588C3.46228 11.8444 3.66432 12.6051 3.95564 13.371V13.3715Z"/>
