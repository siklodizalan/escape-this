{%- liquid
  assign padding_horizontal = section.settings.padding_horizontal
  assign padding_horizontal_mobile = section.settings.padding_horizontal_mobile
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign border_color = section.settings.border_color
  assign border_thickness = section.settings.border_thickness
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign margin_horizontal_mobile = section.settings.margin_horizontal_mobile
  assign margin_horizontal = section.settings.margin_horizontal
  assign background_color = section.settings.background_color
  assign background_gradient = section.settings.background_gradient
  assign full_width = section.settings.full_width
  assign section_radius = section.settings.section_radius

  assign caption_block = section.blocks | where: 'type', 'caption' | first
  assign heading_block = section.blocks | where: 'type', 'heading' | first
  assign text_block = section.blocks | where: 'type', 'text' | first
  assign feature_blocks = section.blocks | where: 'type', 'feature'
  assign category_blocks = section.blocks | where: 'type', 'category'

  assign tab_active_bg = section.settings.tab_active_bg
  assign tab_active_text = section.settings.tab_active_text
  assign tab_inactive_border = section.settings.tab_inactive_border
  assign tab_inactive_text = section.settings.tab_inactive_text
  assign tab_radius = section.settings.tab_radius

  assign category_heading_color = section.settings.category_heading_color
  assign category_heading_size = section.settings.category_heading_size
  assign category_heading_size_mobile = section.settings.category_heading_size_mobile
  assign category_text_color = section.settings.category_text_color
  assign category_text_size = section.settings.category_text_size
  assign category_text_size_mobile = section.settings.category_text_size_mobile
  assign category_image_radius = section.settings.category_image_radius

  assign feature_icon_bg_color = section.settings.feature_icon_bg_color
  assign feature_icon_color = section.settings.feature_icon_color
  assign feature_text_color = section.settings.feature_text_color
-%}

{%- style -%}
  .section-{{ section.id }} {
    border-top: solid {{ border_color }} {{ border_thickness }}px;
    border-bottom: solid {{ border_color }} {{ border_thickness }}px;
    margin-top: {{ margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ margin_bottom | times: 0.75 | round: 0 }}px;
    margin-left: {{ margin_horizontal_mobile }}rem;
    margin-right: {{ margin_horizontal_mobile }}rem;
    border-radius: {{ section_radius | times: 0.6 | round: 0 }}px;
    overflow: hidden;
  }

  .section-{{ section.id }}-settings {
    margin: 0 auto;
    padding-top: {{ padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: {{ padding_horizontal_mobile }}rem;
    padding-right: {{ padding_horizontal_mobile }}rem;
  }

  .donations-caption-{{ section.id }} {
    margin: 0;
    font-size: 16px;
    color: #f9f544;
    text-transform: uppercase;
    font-weight: 700;
  }

  .donations-heading-{{ section.id }} {
    margin: 0;
    margin-top: 8px;
    font-size: 28px;
    color: #ffffff;
    text-transform: uppercase;
    font-weight: 800;
    word-break: break-word;
  }

  .donations-intro-{{ section.id }} {
    margin: 0;
    margin-top: 16px;
    font-size: 14px;
    line-height: 150%;
    color: #ffffff;
    text-transform: uppercase;
  }

  .donations-features-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 24px;
  }

  .donations-feature-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .donations-feature-icon-{{ section.id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 5px;
    background-color: {{ feature_icon_bg_color }};
  }

  .donations-feature-icon-{{ section.id }} svg {
    width: 16px;
    height: auto;
  }

  .donations-feature-icon-{{ section.id }} svg path {
    fill: {{ feature_icon_color }};
  }

  .donations-feature-text-{{ section.id }} {
    margin: 0;
    font-size: 14px;
    font-weight: 700;
    color: {{ feature_text_color }};
    text-transform: uppercase;
  }

  .donations-tabs-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .donations-tab-{{ section.id }} {
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 41px;
    padding: 0 25px;
    border-radius: {{ tab_radius }}px;
    border: 1px solid {{ tab_inactive_border }};
    background-color: transparent;
    color: {{ tab_inactive_text }};
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    white-space: nowrap;
    transition: all 0.2s ease;
  }

  .donations-tab-{{ section.id }}.is-active {
    background-color: {{ tab_active_bg }};
    border-color: {{ tab_active_bg }};
    color: {{ tab_active_text }};
  }

  .donations-panels-{{ section.id }} {
    margin-top: 32px;
  }

  .donations-panel-{{ section.id }} {
    display: none;
    flex-direction: column;
    gap: 24px;
  }

  .donations-panel-{{ section.id }}.is-active {
    display: flex;
  }

  .donations-panel-content-{{ section.id }} {
    display: flex;
    flex-direction: column;
  }

  .donations-panel-heading-{{ section.id }} {
    margin: 0;
    font-size: {{ category_heading_size_mobile }}px;
    color: {{ category_heading_color }};
    text-transform: uppercase;
    font-weight: 800;
    word-break: break-word;
  }

  .donations-panel-text-{{ section.id }} {
    margin: 0;
    margin-top: 16px;
    font-size: {{ category_text_size_mobile }}px;
    line-height: 150%;
    color: {{ category_text_color }};
    text-transform: uppercase;
  }

  .donations-panel-text-{{ section.id }} * {
    margin: 0;
    font-size: {{ category_text_size_mobile }}px;
    line-height: 150%;
    color: {{ category_text_color }};
    text-transform: uppercase;
  }

  .donations-panel-button-{{ section.id }} {
    align-self: flex-start;
    margin-top: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 41px;
    padding: 0 25px;
    border-radius: {{ tab_radius }}px;
    background-color: {{ tab_active_bg }};
    color: {{ tab_active_text }};
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: none;
    border: 0;
  }

  .donations-panel-image-{{ section.id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 15 / 7;
    border-radius: {{ category_image_radius }}px;
    overflow: hidden;
  }

  .donations-panel-image-{{ section.id }} img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media(min-width: 1024px) {
    .section-{{ section.id }} {
      margin-top: {{ margin_top }}px;
      margin-bottom: {{ margin_bottom }}px;
      margin-left: {{ margin_horizontal }}rem;
      margin-right: {{ margin_horizontal }}rem;
      border-radius: {{ section_radius }}px;
    }

    .section-{{ section.id }}-settings {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      padding-left: {{ padding_horizontal }}rem;
      padding-right: {{ padding_horizontal }}rem;
    }

    .donations-caption-{{ section.id }} {
      font-size: 20px;
    }

    .donations-heading-{{ section.id }} {
      font-size: 40px;
    }

    .donations-intro-{{ section.id }} {
      font-size: 16px;
    }

    .donations-panel-{{ section.id }} {
      flex-direction: row;
      align-items: center;
      gap: 40px;
    }

    .donations-panel-content-{{ section.id }},
    .donations-panel-image-{{ section.id }} {
      flex: 1 1 0;
      min-width: 0;
    }

    .donations-panel-heading-{{ section.id }} {
      font-size: {{ category_heading_size }}px;
    }

    .donations-panel-text-{{ section.id }},
    .donations-panel-text-{{ section.id }} * {
      font-size: {{ category_text_size }}px;
    }

    .donations-panel-image-{{ section.id }} {
      aspect-ratio: 15 / 7;
    }

    /* Image always on the right, text always on the left - no alternating. */
    .donations-panel-content-{{ section.id }} {
      order: 1;
    }

    .donations-panel-image-{{ section.id }} {
      order: 2;
    }
  }
{%- endstyle -%}

{% unless full_width %}
  <style>
    .section-{{ section.id }}-settings {
      max-width: clamp(100px, var(--page-content-width, var(--page-width)), 100%);
    }
  </style>
{% endunless %}

{% if margin_horizontal_mobile > 0 %}
  <style>
    .section-{{ section.id }} {
      border-left: solid {{ border_color }} {{ border_thickness }}px;
      border-right: solid {{ border_color }} {{ border_thickness }}px;
    }

    @media(min-width: 1024px) {
      .section-{{ section.id }} {
        border-left: 0px;
        border-right: 0px;
      }
    }
  </style>
{% endif %}

{% if margin_horizontal > 0 %}
  <style>
    @media(min-width: 1024px) {
      .section-{{ section.id }} {
        border-left: solid {{ border_color }} {{ border_thickness }}px;
        border-right: solid {{ border_color }} {{ border_thickness }}px;
      }
    }
  </style>
{% endif %}

<div class="section-{{ section.id }}" data-section-id="{{ section.id }}" style="background-color:{{ background_color }}; background-image: {{ background_gradient }};">
  <div class="section-{{ section.id }}-settings">
    {% if caption_block and caption_block.settings.caption != blank %}
      <p class="donations-caption-{{ section.id }}" {{ caption_block.shopify_attributes }}>{{ caption_block.settings.caption }}</p>
    {% endif %}

    {% if heading_block and heading_block.settings.heading != blank %}
      <h2 class="donations-heading-{{ section.id }}" {{ heading_block.shopify_attributes }}>{{ heading_block.settings.heading }}</h2>
    {% endif %}

    {% if text_block and text_block.settings.text != blank %}
      <div class="donations-intro-{{ section.id }}" {{ text_block.shopify_attributes }}>{{ text_block.settings.text }}</div>
    {% endif %}

    {% if feature_blocks.size > 0 %}
      <div class="donations-features-{{ section.id }}">
        {% for block in feature_blocks %}
          <div class="donations-feature-{{ section.id }}" {{ block.shopify_attributes }}>
