{%- liquid
  assign padding_horizontal = section.settings.padding_horizontal
  assign padding_horizontal_mobile = section.settings.padding_horizontal_mobile
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign border_color = section.settings.border_color
  assign border_thickness = section.settings.border_thickness
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign margin_horizontal_mobile = section.settings.margin_horizontal_mobile
  assign margin_horizontal = section.settings.margin_horizontal
  assign background_color = section.settings.background_color
  assign background_gradient = section.settings.background_gradient
  assign full_width = section.settings.full_width
  assign section_radius = section.settings.section_radius

  assign cards_gap = section.settings.cards_gap
  assign cards_gap_mobile = section.settings.cards_gap_mobile
  assign columns_desktop = section.settings.columns_desktop
  assign card_radius = section.settings.card_radius
  assign card_height = section.settings.card_height
  assign card_height_mobile = section.settings.card_height_mobile
  assign grid_mt = section.settings.grid_mt
  assign grid_mt_mobile = section.settings.grid_mt_mobile

  assign overlay_bg_color = section.settings.overlay_bg_color
  assign overlay_text_color = section.settings.overlay_text_color
  assign overlay_hover_color = section.settings.overlay_hover_color
  assign overlay_font = section.settings.overlay_font
  assign overlay_size = section.settings.overlay_size
  assign overlay_size_mobile = section.settings.overlay_size_mobile
  assign overlay_radius = section.settings.overlay_radius

  assign collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show
  assign products_to_display = collection.all_products_count
  if collection.all_products_count > products_to_show
    assign products_to_display = products_to_show
  endif

  assign use_game_blocks = false
  if section.blocks.size > 0
    assign use_game_blocks = true
  endif

  assign has_city_game = false
  assign has_gastro_game = false
  for block in section.blocks
    if block.settings.category == 'city'
      assign has_city_game = true
    endif
    if block.settings.category == 'gastro'
      assign has_gastro_game = true
    endif
  endfor
-%}

{%- style -%}
  {{ overlay_font | font_face: font_display: 'swap' }}

  .section-{{ section.id }} {
    border-top: solid {{ border_color }} {{ border_thickness }}px;
    border-bottom: solid {{ border_color }} {{ border_thickness }}px;
    margin-top: {{ margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ margin_bottom | times: 0.75 | round: 0 }}px;
    margin-left: {{ margin_horizontal_mobile }}rem;
    margin-right: {{ margin_horizontal_mobile }}rem;
    border-radius: {{ section_radius | times: 0.6 | round: 0 }}px;
    overflow: hidden;
  }

  .section-{{ section.id }}-settings {
    margin: 0 auto;
    padding-top: {{ padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: {{ padding_horizontal_mobile }}rem;
    padding-right: {{ padding_horizontal_mobile }}rem;
  }

  .games-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: {{ cards_gap_mobile }}px;
    margin-top: {{ grid_mt_mobile }}px;
  }

  .games-card-{{ section.id }} {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: {{ card_radius }}px;
    height: {{ card_height_mobile }}px;
  }

  .games-card-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .games-card-overlay-{{ section.id }} {
    position: absolute;
    left: 16px;
    bottom: 16px;
    max-width: calc(100% - 32px);
    padding: 10px 16px;
    border-radius: {{ overlay_radius }}px;
    background-color: {{ overlay_bg_color }};
    color: {{ overlay_text_color }};
    font-size: {{ overlay_size_mobile }}px;
    line-height: 1.3;
    text-transform: uppercase;
    word-break: break-word;
    transition: color 0.2s ease;
  }

  .games-card-{{ section.id }}:hover .games-card-overlay-{{ section.id }},
  .games-card-{{ section.id }}:focus-visible .games-card-overlay-{{ section.id }} {
    color: {{ overlay_hover_color }};
  }

  @media(min-width: 750px) {
    .games-grid-{{ section.id }} {
      grid-template-columns: repeat({{ columns_desktop }}, minmax(0, 1fr));
      gap: {{ cards_gap }}px;
      margin-top: {{ grid_mt }}px;
    }

    .games-card-{{ section.id }} {
      height: {{ card_height }}px;
    }

    .games-card-overlay-{{ section.id }} {
      font-size: {{ overlay_size }}px;
    }
  }

  @media(min-width: 1024px) {
    .section-{{ section.id }} {
      margin-top: {{ margin_top }}px;
      margin-bottom: {{ margin_bottom }}px;
      margin-left: {{ margin_horizontal }}rem;
      margin-right: {{ margin_horizontal }}rem;
      border-radius: {{ section_radius }}px;
    }

    .section-{{ section.id }}-settings {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      padding-left: {{ padding_horizontal }}rem;
      padding-right: {{ padding_horizontal }}rem;
    }
  }

  button[data-game-filter] {
    cursor: pointer;
  }

  button[data-game-filter][aria-pressed="true"] > p {
    background: #f9f544 !important;
    border-color: #f9f544 !important;
    color: #191919 !important;
  }

  button[data-game-filter][aria-pressed="true"] > p svg path {
    fill: #191919 !important;
  }

  button[data-game-filter][aria-pressed="false"] > p {
    background: transparent !important;
    border: 1px solid #f9f544 !important;
    color: #ffffff !important;
  }

  button[data-game-filter][aria-pressed="false"] > p svg path {
    fill: #ffffff !important;
  }
{%- endstyle -%}

{% unless full_width %}
  <style>
    .section-{{ section.id }}-settings {
      max-width: clamp(100px, var(--page-content-width, var(--page-width)), 100%);
    }
  </style>
{% endunless %}

<div class="section-{{ section.id }}" style="background-color:{{ background_color }}; background-image: {{ background_gradient }};">
  <div class="section-{{ section.id }}-settings">
    {% if use_game_blocks %}
      <div class="games-grid-{{ section.id }}">
        {% for block in section.blocks %}
          {% liquid
            assign product = block.settings.product
            assign category = block.settings.category | default: 'all'
          %}
          {% if product != blank %}
            <a href="{{ product.url }}" class="games-card-{{ section.id }}" data-game-category="{{ category }}" {{ block.shopify_attributes }}>
              {% if product.featured_media %}
                <img
                  srcset="
                    {{ product.featured_media | image_url: width: 400 }} 400w,
                    {{ product.featured_media | image_url: width: 700 }} 700w,
                    {{ product.featured_media | image_url: width: 1000 }} 1000w
                  "
                  src="{{ product.featured_media | image_url: width: 700 }}"
                  sizes="(min-width: 750px) calc(100vw / {{ columns_desktop }}), 100vw"
                  alt="{{ product.featured_media.alt | escape }}"
                  loading="lazy"
                  width="{{ product.featured_media.width }}"
                  height="{{ product.featured_media.height }}"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag }}
              {% endif %}
              <span class="games-card-overlay-{{ section.id }}">
                {{ product.title }}
                {% if product.price_varies %}
                  | AB {{ product.price_min | money }}
                {% else %}
                  | {{ product.price | money }}
                {% endif %}
              </span>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    {% elsif collection != blank %}
      <div class="games-grid-{{ section.id }}">
        {% for product in collection.products limit: products_to_display %}
          <a href="{{ product.url }}" class="games-card-{{ section.id }}" data-game-category="all">
            {% if product.featured_media %}
              <img
                srcset="
                  {{ product.featured_media | image_url: width: 400 }} 400w,
                  {{ product.featured_media | image_url: width: 700 }} 700w,
                  {{ product.featured_media | image_url: width: 1000 }} 1000w
                "
                src="{{ product.featured_media | image_url: width: 700 }}"
                sizes="(min-width: 750px) calc(100vw / {{ columns_desktop }}), 100vw"
                alt="{{ product.featured_media.alt | escape }}"
                loading="lazy"
                width="{{ product.featured_media.width }}"
                height="{{ product.featured_media.height }}"
              >
            {% else %}
              {{ 'product-1' | placeholder_svg_tag }}
            {% endif %}
            <span class="games-card-overlay-{{ section.id }}">
              {{ product.title }}
              {% if product.price_varies %}
                | AB {{ product.price_min | money }}
              {% else %}
                | {{ product.price | money }}
              {% endif %}
            </span>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<script>
  (function () {
    var hasCity = {{ has_city_game | json }};
    var hasGastro = {{ has_gastro_game | json }};

    var mixed = hasCity && hasGastro;

    document.querySelectorAll('[data-game-filter]').forEach(function (btn) {
      var filter = btn.getAttribute('data-game-filter');
      var visible;
      if (mixed) {
        visible = true;
      } else if (hasCity) {
        visible = filter === 'city';
      } else if (hasGastro) {
        visible = filter === 'gastro';
      } else {
        visible = filter === 'all';
      }
      btn.style.display = visible ? '' : 'none';

      // Default active filter: "all" when categories are mixed, otherwise
      // whichever single button remains visible (it's always the active one).
      var isDefaultActive = mixed ? filter === 'all' : visible;
      btn.setAttribute('aria-pressed', isDefaultActive ? 'true' : 'false');
    });

    if (window.__gamesFilterClickInit) return;
    window.__gamesFilterClickInit = true;

    document.addEventListener('click', function (event) {
      var btn = event.target.closest('[data-game-filter]');
      if (!btn) return;

      var filter = btn.getAttribute('data-game-filter');
      var group = btn.closest('[class*="hero-buttons-"]');
      if (group) {
        group.querySelectorAll('[data-game-filter]').forEach(function (b) {
          b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
        });
      }

      document.querySelectorAll('[data-game-category]').forEach(function (card) {
        var category = card.getAttribute('data-game-category');
        var show = filter === 'all' || category === 'all' || category === filter;
        card.style.display = show ? '' : 'none';
      });
    });
  })();
</script>

{% schema %}
