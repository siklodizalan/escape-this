{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="contact page-width page-width--narrow section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank -%}
      <h2 class="title title-wrapper--no-top-margin inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.heading }}
      </h2>
    {%- else -%}
      <h2 class="visually-hidden">Widerrufsformular</h2>
    {%- endif -%}
    {%- liquid
      assign cancellation_form_class = 'isolate'
      if settings.animations_reveal_on_scroll
        assign cancellation_form_class = 'isolate scroll-trigger animate--slide-in'
      endif
    -%}
    
    {%- form 'contact', id: 'CancellationForm', class: cancellation_form_class -%}
      {%- if form.posted_successfully? -%}
        <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
          {{- 'icon-success.svg' | inline_asset_content -}}
          Ihr Widerruf wurde erfolgreich übermittelt und wird bearbeitet.
        </h2>
      {%- elsif form.errors -%}
        <div class="form__message">
          <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
            {{- 'icon-error.svg' | inline_asset_content -}}
            Bitte überprüfen Sie Ihre Eingaben.
          </h2>
        </div>
        <ul class="form-status-list caption-large" role="list">
          {%- for field in form.errors -%}
            <li>
              <span class="link">
                {{ field | capitalize }} {{ form.errors.messages[field] }}
              </span>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <input type="hidden" name="contact[Betreff]" value="FORMULAR: Gesetzlicher Widerruf">
      <input type="hidden" name="contact[Formular_Typ]" value="Widerruf_Automatisierung">

      <div class="field" style="margin-bottom: 2rem;">
        <input
          class="field__input"
          autocomplete="name"
          type="text"
          id="CancellationForm-name"
          name="contact[{{ 'templates.contact.form.name' | t }}]"
          value="{% if customer %}{{ customer.name }}{% endif %}"
          placeholder="Name"
          required
        >
        <label class="field__label" for="CancellationForm-name">Name <span aria-hidden="true">*</span></label>
      </div>

      <div class="field" style="margin-bottom: 2rem;">
        <input
          autocomplete="email"
          type="email"
          id="CancellationForm-email"
          class="field__input"
          name="contact[email]"
          spellcheck="false"
          autocapitalize="off"
          value="{% if customer %}{{ customer.email }}{% endif %}"
          placeholder="E-Mail-Adresse"
          required
        >
        <label class="field__label" for="CancellationForm-email">E-Mail-Adresse <span aria-hidden="true">*</span></label>
      </div>
      
      <div class="field" style="margin-bottom: 2rem;">
        <input
          type="text"
          id="CancellationForm-order"
          class="field__input"
          name="contact[Bestellnummer]"
          placeholder="Bestellnummer (z.B. #1001)"
          required
        >
        <label class="field__label" for="CancellationForm-order">Bestellnummer <span aria-hidden="true">*</span></label>
      </div>

      <div class="field" style="margin-bottom: 2rem;">
        <textarea
          rows="10"
          id="CancellationForm-body"
          class="text-area field__input"
          name="contact[Zusätzliche Details]"
          placeholder="Zusätzliche Details (Optional)"
        ></textarea>
        <label class="form__label field__label" for="CancellationForm-body">
          Zusätzliche Details (Optional)
        </label>
      </div>

      <div class="contact__button">
        <button type="submit" class="button" style="width: 100%;">
          Widerruf bestätigen
        </button>
      </div>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Widerruf Form",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Widerrufserklärung",
      "label": "t:sections.contact-form.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Widerruf Form"
    }
  ]
}
{% endschema %}