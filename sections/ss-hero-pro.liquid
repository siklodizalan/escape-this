{%- liquid 
  assign padding_horizontal = section.settings.padding_horizontal
  assign padding_horizontal_mobile = section.settings.padding_horizontal_mobile
  assign padding_right_none = section.settings.padding_right_none
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign border_color = section.settings.border_color
  assign border_thickness = section.settings.border_thickness
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign margin_horizontal_mobile = section.settings.margin_horizontal_mobile
  assign margin_horizontal = section.settings.margin_horizontal
  assign background_color = section.settings.background_color
  assign background_gradient = section.settings.background_gradient
  assign width = section.settings.width
  assign content_width = section.settings.content_width
  assign lazy = section.settings.lazy 
  assign section_radius = section.settings.section_radius 
  assign background_style = section.settings.background_style
  
  assign hero_height = section.settings.hero_height
  assign hero_fixed_height = section.settings.hero_fixed_height
  assign hero_fixed_height_mobile = section.settings.hero_fixed_height_mobile

  assign layout_bg_type = section.settings.layout_bg_type  
  
  assign bg_image = section.settings.bg_image
  assign bg_image_mobile = section.settings.bg_image_mobile
  assign bg_video = section.settings.bg_video
  assign bg_video_url = section.settings.bg_video_url

  assign bg_overlay_color = section.settings.bg_overlay_color
  assign bg_overlay = section.settings.bg_overlay

  assign enable_split_layout = section.settings.enable_split_layout
  assign content_align = section.settings.content_align
  assign content_align_mobile = section.settings.content_align_mobile  
  assign content_vertical_align = section.settings.content_vertical_align
  assign content_vertical_align_mobile = section.settings.content_vertical_align_mobile
  assign content_max_width = section.settings.content_max_width

  assign content_horizontal_align = ""
  if content_align == "center"
    assign content_horizontal_align = "center"
  elsif content_align == "right"
    assign content_horizontal_align = "end"
  else
    assign content_horizontal_align = "start"
  endif

  assign content_horizontal_align_mobile = ""
  if content_align_mobile == "center"
    assign content_horizontal_align_mobile = "center"
  elsif content_align_mobile == "right"
    assign content_horizontal_align_mobile = "end"
  else
    assign content_horizontal_align_mobile = "start"
  endif

  assign features_mt = section.settings.features_mt
  assign features_mt_mobile = section.settings.features_mt_mobile
  assign features_gap_mobile = section.settings.features_gap_mobile
  assign features_gap = section.settings.features_gap

  assign feature_border_thickness = section.settings.feature_border_thickness
  assign feature_border_color = section.settings.feature_border_color
  assign feature_padding_vertical = section.settings.feature_padding_vertical
  assign feature_padding_vertical_mobile = section.settings.feature_padding_vertical_mobile
  assign feature_padding_horizontal = section.settings.feature_padding_horizontal
  assign feature_padding_horizontal_mobile = section.settings.feature_padding_horizontal_mobile
  assign feature_radius = section.settings.feature_radius
  assign feature_background = section.settings.feature_background
  assign feature_bg_opacity = section.settings.feature_bg_opacity
  assign feature_enable_blur = section.settings.feature_enable_blur
  assign feature_bg_color = section.settings.feature_bg_color

  assign feature_icon_size = section.settings.feature_icon_size
  assign feature_icon_color = section.settings.feature_icon_color
  assign feature_icon_size_mobile = section.settings.feature_icon_size_mobile

  assign feature_text_custom = section.settings.feature_text_custom
  assign feature_text_font = section.settings.feature_text_font
  assign feature_text_size = section.settings.feature_text_size
  assign feature_text_size_mobile = section.settings.feature_text_size_mobile
  assign feature_text_color = section.settings.feature_text_color
  assign feature_text_height = section.settings.feature_text_height

  assign loading_attribute = 'lazy'
  unless lazy
    assign loading_attribute = 'eager'
  endunless
-%}

{%- style -%}
  .section-{{ section.id }} {
    border-top: solid {{ border_color }} {{ border_thickness }}px;
    border-bottom: solid {{ border_color }} {{ border_thickness }}px;
    margin-top: {{ margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ margin_bottom | times: 0.75 | round: 0 }}px;
    margin-left: {{ margin_horizontal_mobile }}rem;
    margin-right: {{ margin_horizontal_mobile }}rem;
    border-radius: {{ section_radius | times: 0.6 | round: 0 }}px;
    overflow: hidden; 
    position: relative;
  }
  
  .section-{{ section.id }}-settings {
    margin: 0 auto;
    padding-top: {{ padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: {{ padding_horizontal_mobile }}rem;
    padding-right: {% if padding_right_none %}0{% else %}{{ padding_horizontal_mobile }}rem{% endif %};
    height: 100%;
  }
  
  .hero-media-{{ section.id }} .hero-media-image-desktop {
    display: none;
  }

  .hero-media-{{ section.id }} .hero-media-image-mobile {
    display: block;
  }

  .hero-media-{{ section.id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    transform: translate(-50%, -50%);
  }

  .hero-media-{{ section.id }}  {
    grid-area: media;
  }

  
    .hero-body-{{ section.id }} {      
      height: 100%;
    }

  .hero-media-{{ section.id }} img,
  .hero-media-{{ section.id }} svg,
  .hero-media-{{ section.id }} video,
  .hero-media-{{ section.id }} iframe {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 0px;
  }  

  .hero-media-{{ section.id }} svg {
    background-color: #AFAFAF;
  }

  .hero-content-{{ section.id }} {
    width: 100%;
    display: flex;
    flex-direction: column;
    grid-area: content;
    align-items: {{ content_horizontal_align_mobile }};
    justify-content: {{ content_vertical_align_mobile }};
    padding: 0px 16px;
    height: 100%;
  }

  .hero-heading-row-{{ section.id }} {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
  }

  .hero-buttons-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ content_horizontal_align_mobile }};
    gap: 10px;
    justify-content: flex-start;
    flex-wrap: wrap;
    width: 100%;
  }

  @media (max-width: 1023px) {
    .section-{{ section.id }} .hero-buttons-{{ section.id }} > *:not(:first-child) {
      margin-top: 0px !important;
    }
  }

  .hero-features-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ content_horizontal_align_mobile }};
    flex-wrap: wrap;
    gap: {{ features_gap_mobile }}px;
    justify-content: flex-start;
    margin-top: {{ features_mt_mobile }}px;
  }
  
  .hero-feature-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    position: relative;
    z-index: 1;
    {% if content_align_mobile == 'right' %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .hero-feature-text-{{ section.id }} {
    margin: 0;
    font-size: {{ feature_text_size_mobile }}px;
    color: {{ feature_text_color }};
    line-height: {{ feature_text_height }}%;
    text-transform: unset;
    font-weight: var(--font-body-weight);
    text-wrap: balance;
    word-break: break-word;
    text-align: {{ content_align_mobile }};
  }


  .hero-feature-icon-{{ section.id }} {
    flex-shrink: 0;
    height: {{ feature_icon_size_mobile }}px;
    width: {{ feature_icon_size_mobile }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    {% if feature_background %}
      padding: {{ feature_padding_vertical_mobile }}px;
      border: {{ feature_border_thickness }}px solid {{ feature_border_color }};
      border-radius: {{ feature_radius }}px;
      background-color: {{ feature_bg_color | hex_to_rgba: feature_bg_opacity }};
      {% if feature_enable_blur %}
        backdrop-filter: blur(3px);
        -webkit-backdrop-filter: blur(3px);
      {% endif %}
    {% endif %}
  }

  .hero-feature-icon-{{ section.id }} img,
  .hero-feature-icon-{{ section.id }} svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .hero-feature-icon-{{ section.id }} svg path {
    fill: {{ feature_icon_color }};
  }

  .hero-feature-icon-{{ section.id }} svg circle {
    fill: {{ feature_icon_color }};
  }

  .hero-feature-icon-{{ section.id }} .refresh-{{ section.id }} path,
  .hero-feature-icon-{{ section.id }} .refresh-{{ section.id }} polyline{
    fill: none;
    stroke: {{ feature_icon_color }};
  }

  @media(min-width: 1024px) {

    .section-{{ section.id }} {
      margin-top: {{ margin_top }}px;
      margin-bottom: {{ margin_bottom }}px;
      margin-left: {{ margin_horizontal }}rem;
      margin-right: {{ margin_horizontal }}rem;      
      border-radius: {{ section_radius }}px;
      padding-bottom: 0px;
    }

    .section-{{ section.id }}-settings {
      margin: 0 auto;
      padding-top: {{ padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ padding_bottom | times: 0.75 | round: 0 }}px;
      padding-left: {{ padding_horizontal }}rem;
      padding-right: {% if padding_right_none %}0{% else %}{{ padding_horizontal }}rem{% endif %};
    }

    .hero-content-{{ section.id }} {
      height: 100%;
      align-items: {{ content_horizontal_align }};
      justify-content: {{ content_vertical_align }};
      width: {{ content_max_width }}%;
      {% if enable_split_layout %}
        margin-left: auto;
        margin-right: 0;
      {% else %}
        {% if content_align == 'center' %}
          margin: 0 auto;
        {% elsif content_align == 'right' %}
          margin-left: auto;
        {% else %}
          margin-right: auto;
        {% endif %}
      {% endif %}
    }
    
    .hero-buttons-{{ section.id }} {
      flex-direction: row;
      align-items: center;
      justify-content: {{ content_horizontal_align }};
      gap: 16px;
    }

    .hero-features-{{ section.id }} {
      flex-direction: row;
      align-items: center;
      justify-content: {{ content_horizontal_align }};
      gap: {{ features_gap }}px;
      margin-top: {{ features_mt }}px;
    }

    .hero-feature-{{ section.id }} {
      {% if content_align == 'right' %}
        flex-direction: row-reverse;
      {% endif %}
    }
    
    .hero-feature-text-{{ section.id }} {
      font-size: {{ feature_text_size }}px;
      text-align: {{ content_align }};
    }
    
    .hero-feature-icon-{{ section.id }} {
      height: {{ feature_icon_size }}px;
      width: {{ feature_icon_size }}px;
      {% if feature_background %}
        padding: {{ feature_padding_vertical }}px;
      {% endif %}
    }
    
    .hero-media-{{ section.id }} {
      height: 100% !important;
    }
    
    .hero-media-{{ section.id }} .hero-media-image-desktop {
      display: block;
    }

    .hero-media-{{ section.id }} .hero-media-image-mobile {
      display: none;
    }  
  }
  
{%- endstyle -%}


{% if margin_horizontal_mobile > 0 %}
  <style>
    .section-{{ section.id }} {
      border-left: solid {{ border_color }} {{ border_thickness }}px;
      border-right: solid {{ border_color }} {{ border_thickness }}px;
    }
    
    @media(min-width: 1024px) {
      .section-{{ section.id }} {
        border-left: 0px;
        border-right: 0px;
      }
    }
  </style>
{% endif %}

{% if margin_horizontal > 0 %}
  <style>
    @media(min-width: 1024px) {
      .section-{{ section.id }} {
        border-left: solid {{ border_color }} {{ border_thickness }}px;
        border-right: solid {{ border_color }} {{ border_thickness }}px;
      }
    }
  </style>
{% endif %}

{% if width == 'custom' %}
  <style>
    .section-{{ section.id }}-settings {
      max-width: {{ content_width }}px;
    }
  </style>
{% elsif width == 'page' %}
  <style>
    .section-{{ section.id }}-settings {
      max-width: clamp(100px, var(--page-content-width, var(--page-width)), 100%);
    }
  </style>
{% endif %}

{% if feature_text_custom %}
  <style>
    {{  feature_text_font | font_face: font_display: 'swap' }}
    
    .hero-feature-text-{{ section.id }} {
      font-family: {{ feature_text_font.family }}, {{ feature_text_font.fallback_families }};
      font-weight: {{ feature_text_font.weight }};
      font-style: {{ feature_text_font.style }};
    }
  </style>
{% endif %}

{% if hero_height == "full_screen" %}
  <style>
    .hero-{{ section.id }} {
      height: 95vh;
    }
    @media(min-width: 1024px) {      
      .section-{{ section.id }}-settings {
        height: 100%;
      }

      .hero-{{ section.id }} {
        height: 95vh;
      }
    }
  </style>
{% elsif hero_height == 'fixed_height' %}  
  <style>     
    .hero-{{ section.id }} {
      height: {{ hero_fixed_height_mobile }}px;
    }

    @media(min-width: 1024px) {
      .section-{{ section.id }}-settings {
        height: 100%;
      }

      .hero-{{ section.id }} {
        height: {{ hero_fixed_height }}px;
      }
    }
  </style>
{% endif %}


{% for block in section.blocks %}
  {% case block.type %}
    {% when 'review' %}
      {% render 'hero-pro-style-review', block: block, content_align: content_align, content_align_mobile: content_align_mobile %}

    {% when 'heading' %}
      {% render 'hero-pro-style-heading', block: block, content_align: content_align, content_align_mobile: content_align_mobile %}

    {% when 'text' %}
      {% render 'hero-pro-style-text', block: block, content_align: content_align, content_align_mobile: content_align_mobile %}

    {% when 'verified' %}
      {% render 'hero-pro-style-verified',
        block: block,
        section_id: section.id,
        content_align: content_align,
        content_align_mobile: content_align_mobile,
        content_horizontal_align: content_horizontal_align,
        content_horizontal_align_mobile: content_horizontal_align_mobile
      %}

    {% when 'caption' %}
      {% render 'hero-pro-style-caption',
        block: block,
        content_align: content_align,
        content_align_mobile: content_align_mobile,
        content_horizontal_align: content_horizontal_align,
        content_horizontal_align_mobile: content_horizontal_align_mobile
      %}

    {% when 'button' %}
      {% render 'hero-pro-style-button', block: block %}

    {% when 'social_icons' %}
      {% render 'hero-pro-style-social-icons', block: block %}

  {% endcase %}
{% endfor %}



{% if layout_bg_type == 'video' or layout_bg_type == 'image' %}
  <style>
    .hero-media-{{ section.id }}::after {
      content: '';
      position: absolute;
      width: 100%;
      height: 100%;
      left: 0;
      top: 0;
      z-index: 1;
      background-color: {{ bg_overlay_color | hex_to_rgba: bg_overlay }};
      transition: all 0.25s ease 0s;
    }
  </style>
{% endif %}



<div class="section-{{ section.id }} hero-{{ section.id }}" {% if background_style == 'solid' %}style="background-color:{{ background_color }};"{% else %} style="background-image: {{ background_gradient }};"{% endif %}>
    <div class="section-{{ section.id }}-settings">  
      <div class="hero-body-{{ section.id }}">
        <div class="hero-media-{{ section.id }}">
          {% render 'hero-pro-media',
            layout_bg_type: layout_bg_type,
            bg_video: bg_video,
            bg_video_url: bg_video_url,
            bg_image: bg_image,
            bg_image_mobile: bg_image_mobile,
            hero_fixed_height: hero_fixed_height,
            hero_fixed_height_mobile: hero_fixed_height_mobile,
            loading_attribute: loading_attribute,
            lazy: lazy
          %}
        </div>
        <div class="hero-content-{{ section.id }}">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'caption' %}
                {% render 'hero-pro-block-caption', block: block %}

              {% when 'review' %}
                {% render 'hero-pro-block-review', block: block, lazy: lazy %}

              {% when 'heading' %}
                {% render 'hero-pro-block-heading', block: block, blocks: section.blocks, forloop: forloop, section_id: section.id %}

              {% when 'social_icons' %}
                {% render 'hero-pro-block-social-icons', block: block, blocks: section.blocks, forloop: forloop %}

              {% when 'text' %}
                {% render 'hero-pro-block-text', block: block %}

              {% when 'verified' %}
                {% render 'hero-pro-block-verified', block: block, content_width: content_width, loading_attribute: loading_attribute %}

              {% when 'feature' %}
                {% assign next_index = forloop.index0 | plus: 1 %}
                {% assign next_block = section.blocks[next_index] %}

                {% unless feature_open %}
                  <div class="hero-features-{{ section.id }}">
                {% endunless %}

                {% render 'hero-pro-block-feature', block: block, section_id: section.id, content_width: content_width, loading_attribute: loading_attribute %}

                {% assign feature_open = true %}

                {% if next_block.type != "feature" %}
                  </div>
                  {% assign feature_open = false %}
                {% endif %}

              {% when 'button' %}
                {% assign next_index = forloop.index0 | plus: 1 %}
                {% assign next_block = section.blocks[next_index] %}

                {% unless button_open %}
                  <div class="hero-buttons-{{ section.id }}">
                {% endunless %}

                {% render 'hero-pro-block-button', block: block %}

                {% assign button_open = true %}

                {% if next_block.type != "button" %}
                  </div>
                  {% assign button_open = false %}
                {% endif %}
            {% endcase %}
          {% endfor %}
        </div>       
      </div>      
    </div>
</div>

{% if lazy %}
  <script src="https://cdn.jsdelivr.net/npm/vanilla-lazyload@19.1.3/dist/lazyload.min.js"></script>
{% endif %}

<script>
  function initHero47() {      
    {% if lazy %}
      let lazyLoadInstance = new LazyLoad();
      window.addEventListener("LazyLoad::Initialized", function (event) {
        window.lazyLoadInstance = event.detail.instance;
      }, false);
    {% endif %}
  }

  document.addEventListener('DOMContentLoaded', initHero47);

  if (Shopify.designMode) {
    document.addEventListener('shopify:section:unload', initHero47);
    document.addEventListener('shopify:section:load', initHero47);
  }
</script>

{% schema %}
  {
    "name": "SS - Hero pro",
    "tag": "section",
    "class": "section",
    "settings": [
        {
        "type": "header",
        "content": "Layout"
      },
      {
        "type": "select",
        "id": "hero_height",
        "label": "Height",
        "default": "full_screen",
        "options": [
          {
            "label": "Full screen",
            "value": "full_screen"
          },
          {
            "label": "Fixed height",
            "value": "fixed_height"
          },
          {
            "label": "Auto",
            "value": "auto"
          }
        ]
      },
      {
        "type": "range",
        "id": "hero_fixed_height",
        "min": 100,
        "max": 1000,
        "step": 10,
        "unit": "px",
        "label": "Fixed height",
        "default": 600,
        "visible_if": "{{ section.settings.hero_height == 'fixed_height' }}"
      },
         {
        "type": "range",
        "id": "hero_fixed_height_mobile",
        "min": 100,
        "max": 1000,
        "step": 10,
        "unit": "px",
        "label": "Fixed height - mobile",
        "default": 600,
        "visible_if": "{{ section.settings.hero_height == 'fixed_height' }}"
      },   
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "range",
        "id": "content_max_width",
        "min": 30,
        "max": 100,
        "step": 1,
        "unit": "%",
        "label": "Max width",
        "default": 50
      },
      {
        "type": "checkbox",
        "id": "enable_split_layout",
        "label": "Position content on right",
        "default": false,
        "info": "Pushes the content to the right side on desktop, while keeping your chosen text alignment."
      },
      {
        "type": "text_alignment",
        "id": "content_align",
        "label": "Alignment"
      },
      {
        "type": "text_alignment",
        "id": "content_align_mobile",
        "label": "Alignment - mobile",
        "default": "center"
      },     
      {
        "type": "select",
        "id": "content_vertical_align",
        "label": "Position",
        "default": "center",
        "options": [
          {
            "label": "Top",
            "value": "start"
          },
          {
            "label": "Center",
            "value": "center"
          },
          {
            "label": "Bottom",
            "value": "end"
          }
        ]
      },
      {
        "type": "select",
        "id": "content_vertical_align_mobile",
        "label": "Position - mobile",
        "default": "end",
        "options": [
          {
            "label": "Top",
            "value": "start"
          },
          {
            "label": "Center",
            "value": "center"
          },
          {
            "label": "Bottom",
            "value": "end"
          }
        ]
      },
      {
        "type": "header",
        "content": "Features"
      },    
      {
        "type": "checkbox",
        "id": "features_advanced",
        "label": "Show advanced settings",
        "default": false
      },
      {
        "type": "range",
        "id": "features_mt",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Margin top",
        "default": 20,
        "visible_if": "{{ section.settings.features_advanced }}"
      },
      {
        "type": "range",
        "id": "features_mt_mobile",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Margin top - mobile",
        "default": 20,
        "visible_if": "{{ section.settings.features_advanced }}"
      },
      {
        "type": "range",
        "id": "features_gap",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Gap",
        "default": 24,
        "visible_if": "{{ section.settings.features_advanced }}"
      },
      {
        "type": "range",
        "id": "features_gap_mobile",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Gap - mobile",
        "default": 12,
        "visible_if": "{{ section.settings.features_advanced }}"
      },    
      {
        "type": "header",
        "content": "Feature appearance"
      },
      {
        "type": "checkbox",
        "id": "feature_background",
        "label": "Background",
        "default": false
      },
      {
        "type": "range",
        "id": "feature_bg_opacity",
        "min": 0,
        "max": 1,
        "step": 0.1,
        "label": "Opacity",
        "default": 0.3,
        "visible_if": "{{ section.settings.feature_background }}"
      },
      {
        "type": "checkbox",
        "id": "feature_enable_blur",
        "label": "Enable blur",
        "default": true,
        "visible_if": "{{ section.settings.feature_background }}"
      },
      {
        "type": "range",
        "id": "feature_radius",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Roundness",
        "default": 100,
        "visible_if": "{{ section.settings.feature_background }}"
      },
