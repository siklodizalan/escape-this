{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign padding_horizontal = section.settings.padding_horizontal
  assign padding_horizontal_mobile = section.settings.padding_horizontal_mobile
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign border_color = section.settings.border_color
  assign border_thickness = section.settings.border_thickness
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign margin_horizontal_mobile = section.settings.margin_horizontal_mobile
  assign margin_horizontal = section.settings.margin_horizontal
  assign background_color = section.settings.background_color
  assign background_gradient = section.settings.background_gradient
  assign full_width = section.settings.full_width
  assign section_radius = section.settings.section_radius

  assign caption_block = section.blocks | where: 'type', 'caption' | first
  assign heading_block = section.blocks | where: 'type', 'heading' | first
  assign text_block = section.blocks | where: 'type', 'text' | first
  assign form_block = section.blocks | where: 'type', 'email_form' | first
-%}

{%- style -%}
  {% if caption_block %}{{ caption_block.settings.caption_font | font_face: font_display: 'swap' }}{% endif %}
  {% if heading_block %}{{ heading_block.settings.heading_font | font_face: font_display: 'swap' }}{% endif %}
  {% if text_block %}{{ text_block.settings.text_font | font_face: font_display: 'swap' }}{% endif %}

  .section-{{ section.id }} {
    border-top: solid {{ border_color }} {{ border_thickness }}px;
    border-bottom: solid {{ border_color }} {{ border_thickness }}px;
    margin-top: {{ margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ margin_bottom | times: 0.75 | round: 0 }}px;
    margin-left: {{ margin_horizontal_mobile }}rem;
    margin-right: {{ margin_horizontal_mobile }}rem;
    border-radius: {{ section_radius | times: 0.6 | round: 0 }}px;
    overflow: hidden;
  }

  .section-{{ section.id }}-settings {
    margin: 0 auto;
    padding-top: {{ padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: {{ padding_horizontal_mobile }}rem;
    padding-right: {{ padding_horizontal_mobile }}rem;
  }

  .newsletter-body-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .newsletter-caption-{{ section.id }} {
    margin: 0;
    font-size: {% if caption_block %}{{ caption_block.settings.caption_size_mobile }}{% else %}16{% endif %}px;
    color: {% if caption_block %}{{ caption_block.settings.caption_color }}{% else %}#f9f544{% endif %};
    text-transform: uppercase;
    font-weight: 700;
  }

  .newsletter-heading-{{ section.id }} {
    margin: 0;
    margin-top: 8px;
    font-size: {% if heading_block %}{{ heading_block.settings.heading_size_mobile }}{% else %}28{% endif %}px;
    color: {% if heading_block %}{{ heading_block.settings.heading_color }}{% else %}#ffffff{% endif %};
    text-transform: uppercase;
    font-weight: 800;
    word-break: break-word;
  }

  .newsletter-text-{{ section.id }} {
    margin: 0;
    margin-top: 16px;
    max-width: 750px;
    font-size: {% if text_block %}{{ text_block.settings.text_size_mobile }}{% else %}14{% endif %}px;
    line-height: 150%;
    color: {% if text_block %}{{ text_block.settings.text_color }}{% else %}#ffffff{% endif %};
    text-transform: uppercase;
    word-break: break-word;
  }

  .newsletter-form-wrap-{{ section.id }} {
    margin-top: 24px;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .newsletter-field-{{ section.id }} {
    position: relative;
    width: 100%;
    max-width: 459px;
  }

  .newsletter-input-{{ section.id }} {
    width: 100%;
    height: 41px;
    background-color: transparent;
    border: 1px solid {% if form_block %}{{ form_block.settings.input_border_color }}{% else %}#f9f544{% endif %};
    border-radius: {% if form_block %}{{ form_block.settings.input_radius }}{% else %}5{% endif %}px;
    padding: 0 44px 0 20px;
    font-size: 16px;
    color: {% if form_block %}{{ form_block.settings.input_text_color }}{% else %}#ffffff{% endif %};
    appearance: none;
  }

  .newsletter-input-{{ section.id }}:-webkit-autofill,
  .newsletter-input-{{ section.id }}:-webkit-autofill:hover,
  .newsletter-input-{{ section.id }}:-webkit-autofill:focus,
  .newsletter-input-{{ section.id }}:-webkit-autofill:active {
    box-shadow: 0 0 0px 1000px {{ background_color }} inset;
    -webkit-box-shadow: 0 0 0px 1000px {{ background_color }} inset;
    -webkit-text-fill-color: {% if form_block %}{{ form_block.settings.input_text_color }}{% else %}#ffffff{% endif %};
    caret-color: {% if form_block %}{{ form_block.settings.input_text_color }}{% else %}#ffffff{% endif %};
    transition: background-color 9999s ease-in-out 0s;
  }

  .newsletter-input-{{ section.id }}::placeholder {
    color: {% if form_block %}{{ form_block.settings.input_text_color }}{% else %}#ffffff{% endif %};
    text-transform: uppercase;
    opacity: 1;
  }

  .newsletter-submit-{{ section.id }} {
    position: absolute;
    top: 50%;
    right: 16px;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    padding: 0;
    background: none;
    border: 0;
    cursor: pointer;
  }

  .newsletter-submit-{{ section.id }} svg {
    width: 12px;
    height: auto;
    transform: rotate(90deg);
  }

  .newsletter-submit-{{ section.id }} svg path {
    fill: {% if form_block %}{{ form_block.settings.input_text_color }}{% else %}#ffffff{% endif %};
  }

  @media(min-width: 1024px) {
    .section-{{ section.id }} {
      margin-top: {{ margin_top }}px;
      margin-bottom: {{ margin_bottom }}px;
      margin-left: {{ margin_horizontal }}rem;
      margin-right: {{ margin_horizontal }}rem;
      border-radius: {{ section_radius }}px;
    }

    .section-{{ section.id }}-settings {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      padding-left: {{ padding_horizontal }}rem;
      padding-right: {{ padding_horizontal }}rem;
    }

    .newsletter-caption-{{ section.id }} {
      font-size: {% if caption_block %}{{ caption_block.settings.caption_size }}{% else %}20{% endif %}px;
    }

    .newsletter-heading-{{ section.id }} {
      font-size: {% if heading_block %}{{ heading_block.settings.heading_size }}{% else %}40{% endif %}px;
    }

    .newsletter-text-{{ section.id }} {
      font-size: {% if text_block %}{{ text_block.settings.text_size }}{% else %}16{% endif %}px;
    }
  }

  {% if caption_block and caption_block.settings.caption_custom %}
    .newsletter-caption-{{ section.id }} {
      font-family: {{ caption_block.settings.caption_font.family }}, {{ caption_block.settings.caption_font.fallback_families }};
      font-weight: {{ caption_block.settings.caption_font.weight }};
      font-style: {{ caption_block.settings.caption_font.style }};
    }
  {% endif %}

  {% if heading_block and heading_block.settings.heading_custom %}
    .newsletter-heading-{{ section.id }} {
      font-family: {{ heading_block.settings.heading_font.family }}, {{ heading_block.settings.heading_font.fallback_families }};
      font-weight: {{ heading_block.settings.heading_font.weight }};
      font-style: {{ heading_block.settings.heading_font.style }};
    }
  {% endif %}

  {% if text_block and text_block.settings.text_custom %}
    .newsletter-text-{{ section.id }} {
      font-family: {{ text_block.settings.text_font.family }}, {{ text_block.settings.text_font.fallback_families }};
      font-weight: {{ text_block.settings.text_font.weight }};
      font-style: {{ text_block.settings.text_font.style }};
    }
  {% endif %}
{%- endstyle -%}

{% unless full_width %}
  <style>
    .section-{{ section.id }}-settings {
      max-width: clamp(100px, var(--page-content-width, var(--page-width)), 100%);
    }
  </style>
{% endunless %}

{% if margin_horizontal_mobile > 0 %}
  <style>
    .section-{{ section.id }} {
      border-left: solid {{ border_color }} {{ border_thickness }}px;
      border-right: solid {{ border_color }} {{ border_thickness }}px;
    }

    @media(min-width: 1024px) {
      .section-{{ section.id }} {
        border-left: 0px;
        border-right: 0px;
      }
    }
  </style>
{% endif %}

{% if margin_horizontal > 0 %}
  <style>
    @media(min-width: 1024px) {
      .section-{{ section.id }} {
        border-left: solid {{ border_color }} {{ border_thickness }}px;
        border-right: solid {{ border_color }} {{ border_thickness }}px;
      }
    }
  </style>
{% endif %}

<div class="section-{{ section.id }}" style="background-color:{{ background_color }}; background-image: {{ background_gradient }};">
  <div class="section-{{ section.id }}-settings">
    <div class="newsletter-body-{{ section.id }}">
      {% if caption_block and caption_block.settings.caption != blank %}
        <p class="newsletter-caption-{{ section.id }}" {{ caption_block.shopify_attributes }}>{{ caption_block.settings.caption }}</p>
      {% endif %}

      {% if heading_block and heading_block.settings.heading != blank %}
        <h2 class="newsletter-heading-{{ section.id }}" {{ heading_block.shopify_attributes }}>{{ heading_block.settings.heading }}</h2>
      {% endif %}

      {% if text_block and text_block.settings.text != blank %}
        <div class="newsletter-text-{{ section.id }}" {{ text_block.shopify_attributes }}>{{ text_block.settings.text }}</div>
      {% endif %}

      {% if form_block %}
        <div class="newsletter-form-wrap-{{ section.id }}" {{ form_block.shopify_attributes }}>
          {% form 'customer', class: 'newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-field-{{ section.id }}">
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="newsletter-input-{{ section.id }}"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="Newsletter-error--{{ section.id }}"
                {% elsif form.posted_successfully? %}
                  aria-describedby="Newsletter-success--{{ section.id }}"
                {% endif %}
                placeholder="{{ form_block.settings.placeholder }}"
                required
              >
              <button
                type="submit"
                class="newsletter-submit-{{ section.id }}"
                name="commit"
                id="Subscribe--{{ section.id }}"
                aria-label="{{ 'newsletter.button_label' | t }}"
              >
                <svg viewBox="0 0 12.9904 11.25" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6.49519 0L12.9904 11.25H0L6.49519 0Z"/>
                </svg>
              </button>
            </div>
            {%- if form.errors -%}
              <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
                <span class="svg-wrapper">
                  {{- 'icon-error.svg' | inline_asset_content -}}
                </span>
                {{- form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email -}}
              </small>
            {%- endif -%}
            {%- if form.posted_successfully? -%}
              <h3
                class="newsletter-form__message newsletter-form__message--success form__message"
                id="Newsletter-success--{{ section.id }}"
                tabindex="-1"
                autofocus
              >
                <span class="svg-wrapper">
                  {{- 'icon-success.svg' | inline_asset_content -}}
                </span>
                {{- 'newsletter.success' | t }}
              </h3>
            {%- endif -%}
          {% endform %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "SS - Newsletter #1",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "header",
        "content": "Section colors"
      },
      {
        "type": "color",
        "label": "Section background",
        "id": "background_color",
        "default": "#1f1f21"
      },
      {
        "type": "color_background",
        "id": "background_gradient",
        "label": "Section background gradient",
        "info": "Remove gradient to replace with solid colors"
      },
      {
        "type": "color",
        "label": "Border",
        "id": "border_color",
        "default": "#1f1f21"
      },
      {
        "type": "header",
        "content": "Section margin (outside)"
      },
      {
        "type": "range",
        "id": "margin_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Margin top",
        "default": 0
      },
      {
        "type": "range",
        "id": "margin_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Margin bottom",
        "default": 0
      },
      {
        "type": "range",
        "id": "margin_horizontal",
        "min": 0,
        "max": 30,
        "step": 1,
        "unit": "rem",
        "label": "Margin sides",
        "default": 0
      },
      {
        "type": "range",
        "id": "margin_horizontal_mobile",
        "min": 0,
        "max": 15,
        "step": 0.5,
        "unit": "rem",
        "label": "Margin sides mobile",
        "default": 0
      },
      {
        "type": "header",
        "content": "Section padding (inside)"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Padding top",
        "default": 40
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "Padding bottom",
        "default": 52
      },
      {
        "type": "range",
        "id": "padding_horizontal",
        "min": 0,
        "max": 30,
        "step": 1,
        "unit": "rem",
        "label": "Padding sides",
        "default": 5
      },
      {
        "type": "range",
        "id": "padding_horizontal_mobile",
        "min": 0,
        "max": 15,
        "step": 0.5,
        "unit": "rem",
        "label": "Padding sides mobile",
        "default": 1.5
      },
      {
        "type": "header",
        "content": "Section settings"
      },
      {
        "type": "checkbox",
        "id": "full_width",
        "label": "Full width",
        "default": false
      },
      {
        "type": "range",
        "id": "border_thickness",
        "min": 0,
        "max": 50,
        "step": 1,
        "unit": "px",
        "label": "Border thickness",
        "default": 0
      },
      {
        "type": "range",
        "id": "section_radius",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Section roundness",
        "default": 0
      }
    ],
    "blocks": [
      {
        "type": "caption",
        "name": "Caption",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "id": "caption",
            "label": "Caption",
            "default": "ANMELDEN & SPAREN"
          },
          {
            "type": "checkbox",
            "id": "caption_custom",
            "label": "Use custom font",
            "default": true
          },
          {
            "type": "font_picker",
            "id": "caption_font",
            "label": "Font family",
            "default": "red_hat_display_n7"
          },
          {
            "type": "range",
            "id": "caption_size",
            "min": 0,
            "max": 40,
            "step": 1,
            "unit": "px",
            "label": "Font size",
            "default": 20
          },
          {
            "type": "range",
            "id": "caption_size_mobile",
            "min": 0,
            "max": 40,
            "step": 1,
            "unit": "px",
            "label": "Font size - mobile",
            "default": 16
          },
          {
            "type": "color",
            "label": "Color",
            "id": "caption_color",
            "default": "#f9f544"
          }
        ]
      },
      {
        "type": "heading",
        "name": "Heading",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "10% NEWSLETTER-RABATT"
          },
          {
            "type": "checkbox",
            "id": "heading_custom",
            "label": "Use custom font",
            "default": true
          },
          {
            "type": "font_picker",
            "id": "heading_font",
            "label": "Font family",
            "default": "red_hat_display_n8"
          },
          {
            "type": "range",
            "id": "heading_size",
            "min": 0,
            "max": 72,
            "step": 2,
            "unit": "px",
            "label": "Font size",
            "default": 40
          },
          {
            "type": "range",
            "id": "heading_size_mobile",
            "min": 0,
            "max": 72,
            "step": 2,
            "unit": "px",
            "label": "Font size - mobile",
            "default": 28
          },
          {
            "type": "color",
            "label": "Color",
            "id": "heading_color",
            "default": "#ffffff"
          }
        ]
      },
      {
        "type": "text",
        "name": "Text",
        "limit": 1,
        "settings": [
          {
            "type": "richtext",
            "id": "text",
            "label": "Text",
            "default": "<p>Jetzt anmelden & 10% auf dein erstes Abenteuer sparen!</p>"
          },
          {
            "type": "checkbox",
            "id": "text_custom",
            "label": "Use custom font",
            "default": true
          },
          {
            "type": "font_picker",
            "id": "text_font",
            "label": "Font family",
            "default": "red_hat_display_n4"
          },
          {
            "type": "range",
            "id": "text_size",
            "min": 0,
            "max": 30,
            "step": 1,
            "unit": "px",
            "label": "Font size",
            "default": 16
          },
          {
            "type": "range",
            "id": "text_size_mobile",
            "min": 0,
            "max": 30,
            "step": 1,
            "unit": "px",
            "label": "Font size - mobile",
            "default": 14
          },
          {
            "type": "color",
            "label": "Color",
            "id": "text_color",
            "default": "#ffffff"
          }
        ]
      },
      {
        "type": "email_form",
        "name": "Email form",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "id": "placeholder",
            "label": "Placeholder",
            "default": "EMAIL ADRESSE"
          },
          {
            "type": "range",
            "id": "input_radius",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "px",
            "label": "Roundness",
            "default": 5
          },
          {
            "type": "color",
            "label": "Border",
            "id": "input_border_color",
            "default": "#f9f544"
          },
          {
            "type": "color",
            "label": "Text",
            "id": "input_text_color",
            "default": "#ffffff"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "SS - Newsletter #1",
        "blocks": [
          {
            "type": "caption"
          },
          {
            "type": "heading"
          },
          {
            "type": "text"
          },
          {
            "type": "email_form"
          }
        ]
      }
    ]
  }
{% endschema %}
