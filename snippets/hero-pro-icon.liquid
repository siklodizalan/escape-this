{% comment %}
  Renders a single hero-pro icon: a custom uploaded image if present,
  otherwise the matching named SVG icon, otherwise a placeholder.

  Accepts:
  - custom_icon: {Image} optional uploaded image, takes priority over `icon`
  - icon: {String} icon name (one of the named icons below, or 'none')
  - content_width: {Number} section.settings.content_width, used to size the custom_icon srcset
  - loading_attribute: {String} 'lazy' or 'eager'

  Usage:
  {% render 'hero-pro-icon',
    custom_icon: block.settings.custom_icon,
    icon: block.settings.icon,
    content_width: content_width,
    loading_attribute: loading_attribute
  %}
{% endcomment %}
{% if custom_icon != blank %}
  {%- capture sizes -%}(min-width: {{ content_width }}px) {{ content_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2){%- endcapture -%}
  {{ custom_icon | image_url: width: 2000 | image_tag:
    loading: loading_attribute,
    sizes: sizes,
    widths: '750, 1070, 1500, 1780, 2000, 3000, 3840'
  }}
{% else %}
