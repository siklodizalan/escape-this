{% comment %}
  Renders the HTML for a hero-pro 'social_icons' block: one link per platform
  that has a URL set, looped over instead of 5 hand-written copies. Closes
  the heading-row wrapper opened in hero-pro-block-heading.liquid when the
  previous block was a heading.

  Accepts:
  - block: {Object} the social_icons block
  - blocks: {Array} section.blocks, used to peek at the previous block
  - forloop: {Object} the parent for-loop's forloop object

  Usage:
  {% render 'hero-pro-block-social-icons', block: block, blocks: section.blocks, forloop: forloop %}
{% endcomment %}
{% assign prev_index = forloop.index0 | minus: 1 %}
{% assign prev_block = blocks[prev_index] %}
{% assign social_platforms = 'tiktok,instagram,facebook,youtube,pinterest' | split: ',' %}
<div class="hero-social-icons-{{ block.id }}">
  {% for platform in social_platforms %}
    {% assign link_key = platform | append: '_link' %}
    {% assign link = block.settings[link_key] %}
    {% if link != blank %}
      <a href="{{ link }}" class="hero-social-icon-{{ block.id }}">
