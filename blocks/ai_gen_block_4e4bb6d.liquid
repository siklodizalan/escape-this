{% doc %}
  @prompt
    Generiere einen Abschnitt  mit einem Banner der zu einer neuen Seite leitet. Links soll platz für etwas text sein, darunter ein Button und ein Foto rechts.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
  }

  .ai-banner-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-banner-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-banner-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
  }

  .ai-banner-text-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  .ai-banner-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
    align-self: flex-start;
  }

  .ai-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-banner-image-wrapper-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_radius }}px;
    object-fit: cover;
  }

  .ai-banner-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-banner-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-banner-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap | times: 0.7 }}px;
    }

    .ai-banner-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-banner-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-banner-button-{{ ai_gen_id }} {
      align-self: stretch;
      text-align: center;
    }
  }
{% endstyle %}

<div class="ai-banner-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-banner-wrapper-{{ ai_gen_id }}">
    <div class="ai-banner-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-banner-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-banner-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-banner-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>

    <div class="ai-banner-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-banner-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-banner-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-banner-empty-state-{{ ai_gen_id }}">
            Füge ein Bild hinzu
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Banner mit Bild",
  "settings": [
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Überschrift",
      "default": "Entdecke unsere neue Kollektion"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Erlebe spannende Abenteuer und unvergessliche Momente mit unseren neuesten Produkten.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button-Text",
      "default": "Jetzt entdecken"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button-Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximale Breite",
      "min": 800,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Abstand zwischen Text und Bild",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Abstand zwischen Elementen",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Innenabstand vertikal",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Innenabstand horizontal",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Hintergrundfarbe",
      "default": "#1f1f21"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Überschrift-Farbe",
      "default": "#f9f544"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text-Farbe",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typografie"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Überschrift-Größe",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text-Größe",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Button-Stil"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Hintergrundfarbe",
      "default": "#f9f544"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover-Hintergrundfarbe",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Textfarbe",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Text-Größe",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Innenabstand vertikal",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Innenabstand horizontal",
      "min": 16,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Eckenradius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Bild-Stil"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Eckenradius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Banner mit Bild"
    }
  ]
}
{% endschema %}
