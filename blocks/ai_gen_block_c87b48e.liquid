{% doc %}
  @prompt
    bitte erstelle mir mehrere Buttons untereinander 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-button-stack-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-button-stack__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.button_spacing }}px;
    width: 100%;
  }

  .ai-button-stack__button-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_thickness }}px solid {{ block.settings.button_border_color }};
    text-align: center;
  }

  .ai-button-stack__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-button-stack-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<button-stack-{{ ai_gen_id }}
  class="ai-button-stack-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-button-stack__container-{{ ai_gen_id }}">
    {% if block.settings.button_1_text != blank %}
      <a
        href="{{ block.settings.button_1_link }}"
        class="ai-button-stack__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_1_text }}
      </a>
    {% endif %}

    {% if block.settings.button_2_text != blank %}
      <a
        href="{{ block.settings.button_2_link }}"
        class="ai-button-stack__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_2_text }}
      </a>
    {% endif %}

    {% if block.settings.button_3_text != blank %}
      <a
        href="{{ block.settings.button_3_link }}"
        class="ai-button-stack__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_3_text }}
      </a>
    {% endif %}

    {% if block.settings.button_4_text != blank %}
      <a
        href="{{ block.settings.button_4_link }}"
        class="ai-button-stack__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_4_text }}
      </a>
    {% endif %}

    {% if block.settings.button_5_text != blank %}
      <a
        href="{{ block.settings.button_5_link }}"
        class="ai-button-stack__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_5_text }}
      </a>
    {% endif %}
  </div>
</button-stack-{{ ai_gen_id }}>

<script>
  (function() {
    class ButtonStack{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('button-stack-{{ ai_gen_id }}', ButtonStack{{ ai_gen_id }});
  })();
</script>

